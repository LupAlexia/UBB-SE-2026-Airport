@{
    ViewData["Title"] = "Services";
}

<div class="container-fluid d-flex flex-column align-items-center justify-content-center" style="background-color: #F0F4F8; min-height: calc(100vh - 70px); padding: 40px 0;">

    <div class="text-center mb-5">
        <p class="text-muted mb-1" style="font-size: 14px; font-family: 'Segoe UI', sans-serif;">Welcome back</p>
        <h1 class="fw-bold m-0" style="font-size: 38px; color: #111827; font-family: 'Segoe UI', sans-serif;">What would you like to do today?</h1>
        <p class="text-muted mt-2" style="font-size: 15px; font-family: 'Segoe UI', sans-serif;">Choose a service to get started</p>
    </div>

    <div class="d-flex flex-column flex-md-row gap-4 justify-content-center align-items-stretch flex-wrap">

        <a asp-controller="FlightTickets" asp-action="Search" class="text-decoration-none text-start">
            <div class="card shadow-sm border position-relative overflow-hidden h-100 d-flex flex-column"
                 style="width: 300px; min-height: 240px; border-radius: 16px; background-color: #FFFFFF; border-color: #E5E7EB; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer;">

                <div class="position-absolute top-0 start-0 w-100" style="height: 6px; background-color: #6366F1;"></div>

                <div class="card-body d-flex flex-column gap-3 p-4 justify-content-center" style="margin-top: 6px;">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width: 64px; height: 64px; background-color: #F5F3FF;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#6366F1" class="bi bi-airplane" viewBox="0 0 16 16" style="transform: rotate(45deg);"><path d="M6.428 1.151C6.708.591 7.213 0 8 0s1.292.592 1.572 1.151C9.861 1.73 10 2.431 10 3v3.691l2.718 2.038A1.5 1.5 0 0 1 13.333 10H15.5a.5.5 0 0 1 .452.717l-1.5 3A.5.5 0 0 1 14 14H1.5a.5.5 0 0 1-.452-.717l1.5-3A.5.5 0 0 1 3 10h2.167a1.5 1.5 0 0 1 .615-.271L8.5 7.691V3c0-.569.139-1.27.357-1.849M8 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2" /></svg>
                    </div>

                    <div>
                        <h3 class="fw-semibold m-0 mb-1" style="font-size: 20px; color: #111827; font-family: 'Segoe UI', sans-serif;">Flight Management</h3>
                        <p class="text-muted m-0" style="font-size: 13px; line-height: 1.4;">Search and book flights, manage tickets</p>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <span class="badge" style="background-color: #F5F3FF; color: #6366F1; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Flights</span>
                        <span class="badge" style="background-color: #F5F3FF; color: #6366F1; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Booking</span>
                        <span class="badge" style="background-color: #F5F3FF; color: #6366F1; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Memberships</span>
                    </div>
                </div>
            </div>
        </a>

        <a asp-controller="ComplaintTickets" asp-action="Index" class="text-decoration-none text-start">
            <div class="card shadow-sm border position-relative overflow-hidden h-100 d-flex flex-column"
                 style="width: 300px; min-height: 240px; border-radius: 16px; background-color: #FFFFFF; border-color: #E5E7EB; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer;">

                <div class="position-absolute top-0 start-0 w-100" style="height: 6px; background-color: #2BB8C0;"></div>

                <div class="card-body d-flex flex-column gap-3 p-4 justify-content-center" style="margin-top: 6px;">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width: 64px; height: 64px; background-color: #F0FAFA;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#2BB8C0" class="bi bi-chat-left-text" viewBox="0 0 16 16"><path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4.414A2 2 0 0 0 3 11.586l-2 2V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12.793a.5.5 0 0 0 .854.353l2.853-2.853A1 1 0 0 1 4.414 12H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" /><path d="M3 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3 6.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5" /></svg>
                    </div>

                    <div>
                        <h3 class="fw-semibold m-0 mb-1" style="font-size: 20px; color: #111827; font-family: 'Segoe UI', sans-serif;">Customer Support</h3>
                        <p class="text-muted m-0" style="font-size: 13px; line-height: 1.4;">Chat, FAQ, support tickets and reviews</p>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <span class="badge" style="background-color: #F0FAFA; color: #2BB8C0; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Chat Bot</span>
                        <span class="badge" style="background-color: #F0FAFA; color: #2BB8C0; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">FAQ</span>
                        <span class="badge" style="background-color: #F0FAFA; color: #2BB8C0; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Reviews</span>
                    </div>
                </div>
            </div>
        </a>

        <a asp-controller="DutyFree" asp-action="Index" class="text-decoration-none text-start">
            <div class="card shadow-sm border position-relative overflow-hidden h-100 d-flex flex-column"
                 style="width: 300px; min-height: 240px; border-radius: 16px; background-color: #FFFFFF; border-color: #E5E7EB; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer;">

                <div class="position-absolute top-0 start-0 w-100" style="height: 6px; background-color: #F59E0B;"></div>

                <div class="card-body d-flex flex-column gap-3 p-4 justify-content-center" style="margin-top: 6px;">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width: 64px; height: 64px; background-color: #FEF3C7;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#F59E0B" class="bi bi-bag" viewBox="0 0 16 16"><path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1m3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4zM2 5h12v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1z"/></svg>
                    </div>

                    <div>
                        <h3 class="fw-semibold m-0 mb-1" style="font-size: 20px; color: #111827; font-family: 'Segoe UI', sans-serif;">Duty Free Shopping</h3>
                        <p class="text-muted m-0" style="font-size: 13px; line-height: 1.4;">Browse shops, add items to cart</p>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <span class="badge" style="background-color: #FEF3C7; color: #F59E0B; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Shops</span>
                        <span class="badge" style="background-color: #FEF3C7; color: #F59E0B; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Items</span>
                        <span class="badge" style="background-color: #FEF3C7; color: #F59E0B; font-weight: 500; font-size: 11px; padding: 6px 10px; border-radius: 6px;">Cart</span>
                    </div>
                </div>
            </div>
        </a>

    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }
</style>