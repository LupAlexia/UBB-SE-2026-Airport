@model List<AirportApp.ClassLibrary.Entity.Dto.ReviewDTO>
@{
    ViewData["Title"] = "Support Overview";
}

@* Add this line for the upper bar to appear at the top of the page *@
<partial name="_UpperBar" />

<div class="container-fluid p-0" style="background-color: #FFFFFF; min-vh-100;">

    <div id="supportCarousel" class="carousel slide carousel-fade mb-5" data-bs-ride="carousel">
        <div class="carousel-inner" style="height: 400px;">

            <div class="carousel-item active h-100">
                <div class="position-relative h-100 bg-dark">
                    <div class="carousel-caption d-flex flex-column justify-content-center h-100 bottom-0">
                        <h1 class="fw-bold text-white display-4">Premium Customer Support</h1>
                    </div>
                </div>
            </div>

            <div class="carousel-item h-100">
                <div class="position-relative h-100 bg-dark">
                    <div class="carousel-caption d-flex flex-column justify-content-center h-100 bottom-0">
                        <h1 class="fw-bold text-white display-4">Seamless Airport Assistance</h1>
                    </div>
                </div>
            </div>

            <div class="carousel-item h-100">
                <div class="position-relative h-100 bg-dark">
                    <div class="carousel-caption d-flex flex-column justify-content-center h-100 bottom-0">
                        <h1 class="fw-bold text-white display-4">Global Coverage</h1>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="container pb-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold" style="color: #201F1E; font-size: 36px;">What Our Customers Say</h2>
            <div class="mx-auto mt-2" style="height: 3px; width: 50px; background-color: #0078D4;"></div>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-warning text-center mx-auto" style="max-width: 500px;">
                @ViewBag.ErrorMessage
            </div>
        }

        <div class="row g-4 justify-content-center">
            @if (Model != null && Model.Any())
            {
                foreach (var review in Model)
                {
                    <div class="col-12 col-md-6 d-flex justify-content-center">
                        <div class="card p-4 border shadow-sm w-100" style="max-width: 420px; border-radius: 8px; border-color: #EDEBE9; background-color: #FFFFFF;">
                            <div class="card-body p-0 d-flex flex-column gap-3">

                                <div style="color: #0078D4; font-size: 18px; letter-spacing: 2px;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Round(review.overallRating))
                                        {
                                            <span>★</span>
                                        }
                                        else
                                        {
                                            <span style="color: #E1DFDD;">★</span>
                                        }
                                    }
                                </div>

                                <p class="card-text fst-italic" style="color: #201F1E; font-size: 16px; line-height: 1.5; min-height: 70px;">
                                    "@review.message"
                                </p>

                                <div>
                                    <h6 class="fw-bold m-0" style="color: #0078D4; font-size: 16px;">@review.userName</h6>
                                    <small style="color: #605E5C; font-size: 12px;">Verified Traveler</small>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    $(document).ready(function () {
        var myCarousel = document.querySelector('#supportCarousel');
        var carousel = new bootstrap.Carousel(myCarousel, {
            interval: 4000,
            ride: 'carousel'
        });
    });
</script>

