@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-4">
    <h1 class="mb-4">Admin Dashboard</h1>
    <p class="text-muted">Welcome, @User.Identity?.Name</p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">FAQ Management</h5>
                    <p class="card-text">Add and manage frequently asked questions.</p>
                    <a asp-controller="FAQEntries" asp-action="Index" class="btn btn-primary">Manage FAQ</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Complaint Tickets</h5>
                    <p class="card-text">Review and respond to customer complaints.</p>
                    <a asp-controller="ComplaintTickets" asp-action="Index" class="btn btn-primary">Manage Tickets</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Reviews</h5>
                    <p class="card-text">Moderate customer reviews.</p>
                    <a asp-controller="Reviews" asp-action="Index" class="btn btn-primary">Manage Reviews</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Employees</h5>
                    <p class="card-text">Manage flight crew members.</p>
                    <a asp-controller="Employees" asp-action="Index" class="btn btn-primary">Manage Employees</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Routes</h5>
                    <p class="card-text">Configure flight routes.</p>
                    <a asp-controller="Routes" asp-action="Index" class="btn btn-primary">Manage Routes</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Gates & Runways</h5>
                    <p class="card-text">Airport infrastructure management.</p>
                    <a asp-controller="AirportAdministration" asp-action="DisplayConfiguration" class="btn btn-primary">Manage Infrastructure</a>
                </div>
            </div>
        </div>
    </div>
</div>
