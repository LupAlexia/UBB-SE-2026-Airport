@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="container py-4">
    <h1 class="mb-4">Manager Dashboard</h1>
    <p class="text-muted">Welcome, @User.Identity?.Name</p>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Flight Management</h5>
                    <p class="card-text">Add, edit, and manage flights for your company.</p>
                    <a asp-controller="CompanyDashboard" asp-action="Index" class="btn btn-primary">Manage Flights</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Crew Assignment</h5>
                    <p class="card-text">Assign crew members to flights.</p>
                    <a asp-controller="AirportAdministration" asp-action="OpenCrewManagement" class="btn btn-primary">Assign Crew</a>
                </div>
            </div>
        </div>
    </div>
</div>
