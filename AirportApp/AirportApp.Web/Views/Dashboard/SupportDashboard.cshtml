@{
    ViewData["Title"] = "Customer Support";
}

<partial name="_UpperBar" />

<div class="container-fluid py-5" style="background: linear-gradient(180deg, #F7FAFC 0%, #EEF6FF 100%); min-height: calc(100vh - 70px);">
    <div class="text-center mb-5">
        <p class="text-uppercase fw-semibold mb-2" style="letter-spacing: .12em; color: #2BB8C0;">Customer support</p>
        <h1 class="fw-bold m-0" style="font-size: clamp(2rem, 4vw, 3.25rem); color: #111827; font-family: 'Segoe UI', sans-serif;">What can we help you with?</h1>
        <p class="text-muted mt-3 mb-0" style="font-size: 15px; max-width: 48rem; margin-inline: auto;">Choose the path that fits your issue. You can chat with support, read FAQs, file a complaint ticket, or leave a review.</p>
    </div>

    <div class="d-flex flex-column flex-md-row gap-4 justify-content-center align-items-stretch flex-wrap">
        <a asp-controller="ChatBot" asp-action="Index" class="text-decoration-none text-start">
            <div class="card shadow-sm border-0 position-relative overflow-hidden h-100 d-flex flex-column support-card" style="width: 290px; min-height: 240px; border-radius: 18px; background-color: #FFFFFF;">
                <div class="support-accent" style="background-color: #2BB8C0;"></div>
                <div class="card-body d-flex flex-column gap-3 p-4 justify-content-center">
                    <div class="icon-badge" style="background-color: #F0FAFA; color: #2BB8C0;">💬</div>
                    <div>
                        <h3 class="fw-semibold m-0 mb-1" style="font-size: 20px; color: #111827; font-family: 'Segoe UI', sans-serif;">Chat Support</h3>
                        <p class="text-muted m-0" style="font-size: 13px; line-height: 1.4;">Open the guided chat assistant for quick help.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <span class="badge support-badge">Chat Bot</span>
                        <span class="badge support-badge">Live help</span>
                    </div>
                </div>
            </div>
        </a>

        <a asp-controller="FAQEntries" asp-action="Index" class="text-decoration-none text-start">
            <div class="card shadow-sm border-0 position-relative overflow-hidden h-100 d-flex flex-column support-card" style="width: 290px; min-height: 240px; border-radius: 18px; background-color: #FFFFFF;">
                <div class="support-accent" style="background-color: #6366F1;"></div>
                <div class="card-body d-flex flex-column gap-3 p-4 justify-content-center">
                    <div class="icon-badge" style="background-color: #F5F3FF; color: #6366F1;">?</div>
                    <div>
                        <h3 class="fw-semibold m-0 mb-1" style="font-size: 20px; color: #111827; font-family: 'Segoe UI', sans-serif;">FAQ</h3>
                        <p class="text-muted m-0" style="font-size: 13px; line-height: 1.4;">Browse popular questions and answers by category.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <span class="badge support-badge alt">Questions</span>
                        <span class="badge support-badge alt">Answers</span>
                    </div>
                </div>
            </div>
        </a>

        <a asp-controller="ComplaintTickets" asp-action="Index" class="text-decoration-none text-start">
            <div class="card shadow-sm border-0 position-relative overflow-hidden h-100 d-flex flex-column support-card" style="width: 290px; min-height: 240px; border-radius: 18px; background-color: #FFFFFF;">
                <div class="support-accent" style="background-color: #F59E0B;"></div>
                <div class="card-body d-flex flex-column gap-3 p-4 justify-content-center">
                    <div class="icon-badge" style="background-color: #FEF3C7; color: #F59E0B;">📝</div>
                    <div>
                        <h3 class="fw-semibold m-0 mb-1" style="font-size: 20px; color: #111827; font-family: 'Segoe UI', sans-serif;">Complaint Tickets</h3>
                        <p class="text-muted m-0" style="font-size: 13px; line-height: 1.4;">View or create support tickets for follow-up issues.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <span class="badge support-badge warn">Tickets</span>
                        <span class="badge support-badge warn">Status</span>
                    </div>
                </div>
            </div>
        </a>

        <a asp-controller="Reviews" asp-action="Create" class="text-decoration-none text-start">
            <div class="card shadow-sm border-0 position-relative overflow-hidden h-100 d-flex flex-column support-card" style="width: 290px; min-height: 240px; border-radius: 18px; background-color: #FFFFFF;">
                <div class="support-accent" style="background-color: #10B981;"></div>
                <div class="card-body d-flex flex-column gap-3 p-4 justify-content-center">
                    <div class="icon-badge" style="background-color: #ECFDF5; color: #10B981;">★</div>
                    <div>
                        <h3 class="fw-semibold m-0 mb-1" style="font-size: 20px; color: #111827; font-family: 'Segoe UI', sans-serif;">Reviews</h3>
                        <p class="text-muted m-0" style="font-size: 13px; line-height: 1.4;">Share your experience with the airport team.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <span class="badge support-badge green">Feedback</span>
                        <span class="badge support-badge green">Ratings</span>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
    .support-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .support-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12) !important;
    }

    .support-accent {
        position: absolute;
        inset: 0 auto auto 0;
        width: 100%;
        height: 6px;
    }

    .icon-badge {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 700;
    }

    .support-badge {
        background-color: #F0FAFA;
        color: #2BB8C0;
        font-weight: 500;
        font-size: 11px;
        padding: 6px 10px;
        border-radius: 6px;
    }

    .support-badge.alt {
        background-color: #F5F3FF;
        color: #6366F1;
    }

    .support-badge.warn {
        background-color: #FEF3C7;
        color: #F59E0B;
    }

    .support-badge.green {
        background-color: #ECFDF5;
        color: #10B981;
    }
</style>
