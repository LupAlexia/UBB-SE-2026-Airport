@using AirportApp.ClassLibrary.Entity.Domain
@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Text.Json
@model IEnumerable<AirportApp.ClassLibrary.Entity.Domain.ComplaintTicket>

@{
    ViewData["Title"] = "Support Tickets";
    TicketFilterStatusEnum selectedStatus = ViewBag.SelectedStatus is TicketFilterStatusEnum filter
        ? filter
        : TicketFilterStatusEnum.ALL;
    bool isEmployee = User.IsInRole("Employee");
    bool isCustomer = User.IsInRole("Customer");
    var categoryItems = ViewBag.Categories as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    string subcategoryDetails = JsonSerializer.Serialize(ViewBag.SubcategoryDetails ?? Array.Empty<object>());
}

<section class="ticket-page">
    <div class="ticket-header">
        <div class="ticket-header-icon" aria-hidden="true">
            <span></span>
        </div>
        <div>
            <h1>Support Tickets</h1>
            <p>@(isEmployee ? "Resolve the requests of our customers." : "Submit and track your support requests. We make sure everyone knows you're complaining.")</p>
        </div>
    </div>

    @if (isCustomer)
    {
        <button type="button" class="btn ticket-primary-action" data-bs-toggle="modal" data-bs-target="#createTicketModal">
            Create new ticket
        </button>

        <div class="modal fade" id="createTicketModal" tabindex="-1" aria-labelledby="createTicketModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content ticket-modal">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div class="modal-header">
                            <h2 class="modal-title fs-5" id="createTicketModalLabel">Submit a New Ticket</h2>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="ticket-form-grid">
                                <div>
                                    <label for="ticketSubject" class="form-label">Title of the issue*</label>
                                    <input id="ticketSubject" name="Subject" class="form-control" maxlength="200" placeholder="e.g. Damaged suitcase" required />
                                </div>

                                <div>
                                    <label for="ticketCategory" class="form-label">Category*</label>
                                    <select id="ticketCategory" name="CategoryId" class="form-select" required>
                                        <option value="">Select Category</option>
                                        @foreach (SelectListItem category in categoryItems)
                                        {
                                            <option value="@category.Value">@category.Text</option>
                                        }
                                    </select>
                                </div>

                                <div>
                                    <label for="ticketSubcategory" class="form-label">Subcategory*</label>
                                    <select id="ticketSubcategory" name="SubcategoryId" class="form-select" required>
                                        <option value="">Select Subcategory</option>
                                    </select>
                                </div>

                                <div>
                                    <label for="ticketUrgency" class="form-label">Urgency Level</label>
                                    <select id="ticketUrgency" name="UrgencyLevel" class="form-select">
                                        <option value="">Use category default</option>
                                        @foreach (ComplaintTicketUrgencyLevelEnum urgency in Enum.GetValues<ComplaintTicketUrgencyLevelEnum>())
                                        {
                                            <option value="@urgency">@FormatStatus(urgency.ToString())</option>
                                        }
                                    </select>
                                </div>

                                <div class="ticket-form-wide">
                                    <label for="ticketDescription" class="form-label">Description*</label>
                                    <textarea id="ticketDescription" name="Description" class="form-control" rows="5" placeholder="Details..." required></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn ticket-secondary-action" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn ticket-primary-action">Send</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <div class="ticket-panel">
        <div class="ticket-panel-header">
            <div>
                <h2>Tickets</h2>
                <p>@(isEmployee ? "Change the status of submitted tickets." : "Track the status of your submitted tickets")</p>
            </div>

            <form asp-action="Index" method="get" class="ticket-filter">
                <span aria-hidden="true">Filter</span>
                <select name="status" class="form-select" onchange="this.form.submit()">
                    @foreach (TicketFilterStatusEnum status in Enum.GetValues<TicketFilterStatusEnum>())
                    {
                        <option value="@status" selected="@(selectedStatus == status)">
                            @FormatStatus(status.ToString())
                        </option>
                    }
                </select>
            </form>
        </div>

        <div class="ticket-list">
            @if (!Model.Any())
            {
                <div class="ticket-empty">
                    <strong>No tickets found</strong>
                    <span>Try another filter or create a new support ticket.</span>
                </div>
            }
            else
            {
                foreach (var item in Model)
                {
                    string statusClass = item.CurrentStatus switch
                    {
                        ComplaintTicketStatusEnum.OPEN => "ticket-status-open",
                        ComplaintTicketStatusEnum.IN_PROGRESS => "ticket-status-progress",
                        ComplaintTicketStatusEnum.RESOLVED => "ticket-status-resolved",
                        _ => "ticket-status-open"
                    };

                    string urgencyClass = item.UrgencyLevel switch
                    {
                        ComplaintTicketUrgencyLevelEnum.HIGH => "ticket-urgency-high",
                        ComplaintTicketUrgencyLevelEnum.MEDIUM => "ticket-urgency-medium",
                        _ => "ticket-urgency-low"
                    };

                    <article class="ticket-card">
                        <div class="ticket-card-main">
                            <div class="ticket-card-top">
                                <span class="ticket-id">#@item.Id</span>
                                <div class="ticket-badges">
                                    <span class="ticket-badge @statusClass">@FormatStatus(item.CurrentStatus.ToString())</span>
                                    <span class="ticket-badge @urgencyClass">@FormatStatus(item.UrgencyLevel.ToString())</span>
                                </div>
                            </div>

                            <h3>@item.Subject</h3>
                            <p class="ticket-description">@item.Description</p>
                            <p class="ticket-meta">
                                <span>Category: @(item.Category?.CategoryName ?? "Unknown")</span>
                                <span>Subcategory: @(item.Subcategory?.SubcategoryName ?? "Unknown")</span>
                                <span>Created: @item.CreationTimestamp.ToLocalTime().ToString("g")</span>
                                <span>Email: @(item.Creator?.EmailAddress ?? "Unknown")</span>
                            </p>
                        </div>

                        @if (isEmployee)
                        {
                            <div class="ticket-card-actions">
                                <button class="btn ticket-primary-action ticket-status-button" type="button" data-bs-toggle="modal" data-bs-target="#statusModal-@item.Id">
                                    Update Status
                                </button>
                            </div>

                            <div class="modal fade" id="statusModal-@item.Id" tabindex="-1" aria-labelledby="statusModalLabel-@item.Id" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content ticket-modal">
                                        <form asp-action="UpdateStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="status" value="@selectedStatus" />
                                            <div class="modal-header">
                                                <h2 class="modal-title fs-5" id="statusModalLabel-@item.Id">Edit CurrentStatus for Ticket #@item.Id</h2>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <label class="form-label" for="currentStatus-@item.Id">Current status</label>
                                                <select id="currentStatus-@item.Id" name="currentStatus" class="form-select">
                                                    @foreach (ComplaintTicketStatusEnum status in Enum.GetValues<ComplaintTicketStatusEnum>())
                                                    {
                                                        <option value="@status" selected="@(item.CurrentStatus == status)">@FormatStatus(status.ToString())</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn ticket-secondary-action" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn ticket-primary-action">Save</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </article>
                }
            }
        </div>
    </div>

    <div class="ticket-legend">
        <div class="ticket-legend-item ticket-legend-open">
            <span class="ticket-legend-icon">â—‹</span>
            <div>
                <strong>Open</strong>
                <p>@(isEmployee ? "Awaiting review" : "Your ticket has been received and is awaiting review")</p>
            </div>
        </div>
        <div class="ticket-legend-item ticket-legend-progress">
            <span class="ticket-legend-icon">â†»</span>
            <div>
                <strong>In Progress</strong>
                <p>@(isEmployee ? "Under investigation" : "An employee is currently investigating or resolving your issue")</p>
            </div>
        </div>
        <div class="ticket-legend-item ticket-legend-resolved">
            <span class="ticket-legend-icon">âœ“</span>
            <div>
                <strong>Resolved</strong>
                <p>@(isEmployee ? "Issue closed" : "Your issue has been addressed and the ticket is closed")</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const subcategories = @Html.Raw(subcategoryDetails);
            const categorySelect = document.getElementById('ticketCategory');
            const subcategorySelect = document.getElementById('ticketSubcategory');

            if (!categorySelect || !subcategorySelect) {
                return;
            }

            function renderSubcategories() {
                const categoryId = Number(categorySelect.value);
                subcategorySelect.innerHTML = '<option value="">Select Subcategory</option>';

                subcategories
                    .filter(subcategory => subcategory.CategoryId === categoryId)
                    .forEach(subcategory => {
                        const option = document.createElement('option');
                        option.value = subcategory.Id;
                        option.textContent = subcategory.Name;
                        subcategorySelect.appendChild(option);
                    });
            }

            categorySelect.addEventListener('change', renderSubcategories);
        })();
    </script>
}

@functions {
    private static string FormatStatus(string value)
    {
        return value.Replace("_", " ").ToLowerInvariant() switch
        {
            "all" => "All Tickets",
            string text => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(text)
        };
    }
}

<style>
    .ticket-page {
        display: grid;
        gap: 1.5rem;
        color: #111827;
    }

    .ticket-header {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .ticket-header h1,
    .ticket-panel h2 {
        margin: 0;
        font-size: 1.75rem;
        font-weight: 600;
    }

    .ticket-header p,
    .ticket-panel p,
    .ticket-empty span {
        margin: .25rem 0 0;
        color: #6b7280;
    }

    .ticket-header-icon {
        width: 3.75rem;
        height: 3.75rem;
        border-radius: 8px;
        background: #2bb8c0;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
    }

    .ticket-header-icon span {
        width: 2rem;
        height: 1.35rem;
        border: 3px solid #fff;
        border-radius: 4px;
        border-top-style: dashed;
    }

    .ticket-primary-action {
        width: fit-content;
        min-width: 11rem;
        background: #2bb8c0;
        border-color: #2bb8c0;
        color: #fff;
        font-weight: 600;
    }

    .ticket-primary-action:hover,
    .ticket-primary-action:focus {
        background: #239ea5;
        border-color: #239ea5;
        color: #fff;
    }

    .ticket-secondary-action {
        border: 1px solid #d1d5db;
        background: #fff;
        color: #374151;
        font-weight: 600;
    }

    .ticket-panel {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 2rem;
    }

    .ticket-panel-header {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ticket-filter {
        display: flex;
        align-items: center;
        gap: .5rem;
        min-width: 15rem;
        color: #6b7280;
        font-weight: 600;
    }

    .ticket-list {
        display: grid;
        gap: 1rem;
    }

    .ticket-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
    }

    .ticket-card-top,
    .ticket-badges,
    .ticket-card-actions {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .ticket-card-top {
        justify-content: space-between;
    }

    .ticket-card h3 {
        margin: .75rem 0 .35rem;
        font-size: 1.05rem;
        font-weight: 700;
    }

    .ticket-id,
    .ticket-meta,
    .ticket-description {
        color: #6b7280;
    }

    .ticket-description {
        margin-bottom: .75rem;
    }

    .ticket-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem .75rem;
        margin: 0;
        font-size: .8rem;
    }

    .ticket-badge {
        border-radius: 4px;
        padding: .2rem .5rem;
        font-size: .75rem;
        font-weight: 700;
    }

    .ticket-status-open { background: #fff4e5; color: #9a5b00; }
    .ticket-status-progress { background: #e5f0ff; color: #245fb3; }
    .ticket-status-resolved { background: #e6ffed; color: #157347; }
    .ticket-urgency-high { background: #ffe2e2; color: #aa161e; }
    .ticket-urgency-medium { background: #fff4e5; color: #9a5b00; }
    .ticket-urgency-low { background: #eef2ff; color: #4f46e5; }

    .ticket-card-actions {
        align-self: start;
        flex-wrap: wrap;
        justify-content: end;
    }

    .ticket-status-button {
        min-width: 8rem;
    }

    .ticket-empty {
        display: grid;
        gap: .25rem;
        border: 1px dashed #d1d5db;
        border-radius: 8px;
        padding: 1.5rem;
        background: #f9fafb;
    }

    .ticket-legend {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        position: sticky;
        bottom: 0;
        z-index: 10;
        padding: .75rem 0;
        background: #f8f9fa;
    }

    .ticket-legend-item {
        display: flex;
        gap: .75rem;
        min-height: 4.5rem;
        padding: 1rem;
        border-radius: 8px;
        align-items: center;
    }

    .ticket-legend-item p {
        margin: .1rem 0 0;
        color: #6b7280;
        font-size: .82rem;
    }

    .ticket-legend-icon {
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1;
    }

    .ticket-legend-open { background: #fff4e5; }
    .ticket-legend-open .ticket-legend-icon { color: #ffb347; }
    .ticket-legend-progress { background: #e5f0ff; }
    .ticket-legend-progress .ticket-legend-icon { color: #5ca0ff; }
    .ticket-legend-resolved { background: #e6ffed; }
    .ticket-legend-resolved .ticket-legend-icon { color: #22c55e; }

    .ticket-modal {
        border-radius: 8px;
        border: 0;
    }

    .ticket-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .ticket-form-wide {
        grid-column: 1 / -1;
    }

    @@media (max-width: 768px) {
        .ticket-panel-header,
        .ticket-card,
        .ticket-legend,
        .ticket-form-grid {
            grid-template-columns: 1fr;
        }

        .ticket-panel-header {
            display: grid;
        }

        .ticket-filter,
        .ticket-filter select {
            width: 100%;
        }

        .ticket-card-actions {
            justify-content: start;
        }
    }
</style>

