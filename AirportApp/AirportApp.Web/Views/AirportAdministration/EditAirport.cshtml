@model AirportApp.ClassLibrary.Entity.Domain.Airport
@{
	Layout = "_AdministrationLayout";
	bool isNew = Model == null || Model.Id == 0;
	ViewData["Title"] = isNew ? "Add New Airport" : "Edit Existing Airport";
	ViewData["ActiveSection"] = "Airport";
}

<div class="d-flex justify-content-center align-items-center mt-5">
	<div class="card bg-slate border-secondary shadow-lg" style="width: 450px;">
		<div class="card-header border-secondary py-3">
			<h4 class="text-white fw-bold mb-0">@ViewData["Title"]</h4>
		</div>
		<div class="card-body p-4 text-white">
			<form asp-action="@(isNew ? "CreateAirport" : "EditAirport")" method="post">
				@if (!isNew)
				{
					<input type="hidden" asp-for="Id" />
				}
				
				<div class="mb-3">
					<label class="form-label small fw-bold text-uppercase">Name</label>
					<input asp-for="Name" class="form-control bg-dark text-white border-secondary"
						   placeholder="Full airport name" />
					<span asp-validation-for="Name" class="text-danger small"></span>
				</div>

				<div class="mb-3">
					<label class="form-label small fw-bold text-uppercase">City</label>
					<input asp-for="City" class="form-control bg-dark text-white border-secondary"
						   placeholder="Location city" />
					<span asp-validation-for="City" class="text-danger small"></span>
				</div>

				<div class="mb-4">
					<label class="form-label small fw-bold text-uppercase">Code</label>
					<input asp-for="Code" class="form-control bg-dark text-white border-secondary"
						   placeholder="e.g. MUC" maxlength="10" />
					<span asp-validation-for="Code" class="text-danger small"></span>
				</div>

				<div class="row g-2">
					<div class="col-6">
						<a asp-action="DisplayConfiguration" class="btn btn-secondary w-100 fw-bold">Cancel</a>
					</div>
					<div class="col-6">
						<button type="submit" class="btn w-100 fw-bold" style="background-color: #D8B4FE; color: #1E293B;">
							Save
						</button>
					</div>
				</div>
			</form>
		</div>
	</div>
</div>
