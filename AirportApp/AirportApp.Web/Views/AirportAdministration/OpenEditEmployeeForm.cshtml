@model AirportApp.Web.Models.AirportManagement.EmployeeFormModel
@{
	Layout = "_AdministrationLayout";
	ViewData["Title"] = "Edit Employee";
}

<div class="d-flex justify-content-center align-items-center mt-5">
	<div class="card bg-slate border-secondary shadow-lg" style="width: 450px;">
		<div class="card-header border-secondary py-3">
			<h4 class="text-white fw-bold mb-0">Edit @Model.Role</h4>
		</div>
		<div class="card-body p-4">
			<form asp-action="ExecuteSaveEmployee" method="post">
				<input type="hidden" asp-for="Id" />
				<input type="hidden" asp-for="Role" />

				<div class="mb-3">
					<label class="form-label text-muted small fw-bold">ROLE</label>
					<input type="text" class="form-control bg-dark text-white border-secondary opacity-50"
						   value="@Model.Role" readonly tabindex="-1" />
				</div>

				<div class="mb-3">
					<label class="form-label text-muted small fw-bold">NAME</label>
					<input asp-for="Name" class="form-control bg-dark text-white border-secondary"
						   placeholder="Enter full name" />
					<span asp-validation-for="Name" class="text-danger small"></span>
				</div>

				<div class="mb-3">
					<label class="form-label text-muted small fw-bold">ANNUAL SALARY</label>
					<input asp-for="Salary" type="number" class="form-control bg-dark text-white border-secondary"
						   placeholder="e.g. 50000" />
					<span asp-validation-for="Salary" class="text-danger small"></span>
				</div>

				<div class="mb-3">
					<label class="form-label text-muted small fw-bold">DATE OF BIRTH</label>
					<input asp-for="Birthday" type="date" class="form-control bg-dark text-white border-secondary" />
					<span asp-validation-for="Birthday" class="text-danger small"></span>
				</div>

				<div class="mb-4">
					<label class="form-label text-muted small fw-bold">DATE OF HIRE</label>
					<input asp-for="HiringDate" type="date" class="form-control bg-dark text-white border-secondary" />
					<span asp-validation-for="HiringDate" class="text-danger small"></span>
				</div>

				<div class="d-grid gap-2">
					<button type="submit" class="btn btn-warning fw-bold text-dark">Update Record</button>
					<a asp-action="DisplayEmployees" class="btn btn-outline-secondary">Cancel</a>
				</div>
			</form>
		</div>
	</div>
</div>
