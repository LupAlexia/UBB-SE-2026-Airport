@model AirportApp.ClassLibrary.Entity.Domain.Airport
@{
	Layout = "_AdministrationLayout";
	bool isNew = Model == null || Model.Id == 0;
	ViewData["Title"] = isNew ? "Add Destination Airport" : "Edit Destination";
	ViewData["ActiveSection"] = "Airport";
}

<div class="d-flex justify-content-center align-items-center mt-5">
	<div class="card bg-slate border-secondary shadow-lg" style="width: 450px;">
		<div class="card-header border-secondary py-3">
			<h4 class="text-white fw-bold mb-0">@ViewData["Title"]</h4>
		</div>
		<div class="card-body p-4">
			<form asp-action="@(isNew ? "CreateAirport" : "EditAirport")" method="post">
				@if (!isNew)
				{
					<input type="hidden" asp-for="Id" />
				}

				<div class="mb-3">
					<label class="form-label text-muted small fw-bold">AIRPORT NAME</label>
					<input asp-for="Name" class="form-control bg-dark text-white border-secondary" placeholder="Full airport name" />
					<span asp-validation-for="Name" class="text-danger small"></span>
				</div>

				<div class="mb-3">
					<label class="form-label text-muted small fw-bold">CITY</label>
					<input asp-for="City" class="form-control bg-dark text-white border-secondary" />
					<span asp-validation-for="City" class="text-danger small"></span>
				</div>

				<div class="mb-4">
					<label class="form-label text-muted small fw-bold">IATA CODE</label>
					<input asp-for="Code" class="form-control bg-dark text-white border-secondary" placeholder="e.g. LHR" />
					<span asp-validation-for="Code" class="text-danger small"></span>
				</div>

				<div class="d-grid gap-2">
					<button type="submit" class="btn btn-info fw-bold">Save Destination</button>
					<a asp-action="DisplayConfiguration" class="btn btn-outline-secondary">Cancel</a>
				</div>
			</form>
		</div>
	</div>
</div>
