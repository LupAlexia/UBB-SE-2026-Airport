@model AirportApp.Web.Models.AirportManagement.AirportAdminViewModel
@{
	Layout = "_AdministrationLayout";
	ViewData["Title"] = "Airport Administration";
}

<div class="container-fluid bg-dark-navy text-white min-vh-100 p-4">

	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="fw-bold"><i class="bi bi-airplane-engines"></i> AIRPORT ADMINISTRATION</h2>
	</div>

	<div class="row g-4">
		<div class="col-md-4">
			<div class="card bg-slate border-secondary h-100 shadow">
				<div class="card-header d-flex justify-content-between align-items-center">
					<h5 class="mb-0">Runways</h5>
					<div class="btn-group">
						<a asp-action="CreateRunway" class="btn btn-sm btn-outline-info">Add</a>
					</div>
				</div>
				<div class="card-body">
					<ul class="list-group list-group-flush bg-transparent">
						@foreach (var runway in Model.RunwaysList)
						{
							<li class="list-group-item bg-transparent text-white d-flex justify-content-between border-secondary">
								@runway.Name
								<div>
									<a asp-action="EditRunway" asp-route-id="@runway.Id" class="text-warning me-2"><i class="bi bi-pencil"></i></a>
									<a asp-action="DeleteRunway" asp-route-id="@runway.Id" class="text-danger"><i class="bi bi-trash"></i></a>
								</div>
							</li>
						}
					</ul>
				</div>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card bg-slate border-secondary h-100 shadow">
				<div class="card-header d-flex justify-content-between align-items-center">
					<h5 class="mb-0">Gates</h5>
					<a asp-action="CreateGate" class="btn btn-sm btn-outline-info">Add</a>
				</div>
				<div class="card-body">
					<ul class="list-group list-group-flush bg-transparent">
						@foreach (var gate in Model.GatesList)
						{
							<li class="list-group-item bg-transparent text-white d-flex justify-content-between border-secondary">
								@gate.Name
								<div>
									<a asp-action="EditGate" asp-route-id="@gate.Id" class="text-warning me-2"><i class="bi bi-pencil"></i></a>
									<a asp-action="DeleteGate" asp-route-id="@gate.Id" class="text-danger"><i class="bi bi-trash"></i></a>
								</div>
							</li>
						}
					</ul>
				</div>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card bg-slate border-secondary h-100 shadow">
				<div class="card-header d-flex justify-content-between align-items-center">
					<h5 class="mb-0">Destinations</h5>
					<a asp-action="CreateAirport" class="btn btn-sm btn-outline-info">Add</a>
				</div>
				<div class="card-body">
					<ul class="list-group list-group-flush bg-transparent">
						@foreach (var airport in Model.AirportsList)
						{
							<li class="list-group-item bg-transparent text-white d-flex justify-content-between border-secondary">
								@airport.Name
								<div>
									<a asp-action="EditAirport" asp-route-id="@airport.Id" class="text-warning me-2"><i class="bi bi-pencil"></i></a>
									<a asp-action="DeleteAirport" asp-route-id="@airport.Id" class="text-danger"><i class="bi bi-trash"></i></a>
								</div>
							</li>
						}
					</ul>
				</div>
			</div>
		</div>
	</div>
</div>
