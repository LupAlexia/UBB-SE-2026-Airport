@model AirportApp.Web.Models.AirportManagement.FlightsDashboardViewModel
@{
	Layout = "_AdministrationLayout";
	ViewData["Title"] = "Flights Administration";
}

<div class="container-fluid bg-dark-navy text-white min-vh-100 p-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="fw-bold"><i class="bi bi-airplane-fill"></i> FLIGHTS ADMINISTRATION</h2>
		<a asp-action="OpenAddFlightForm" class="btn btn-info">Add Flight</a>
	</div>

	<div class="card bg-slate border-secondary shadow">
		<div class="card-body">
			<form method="get" class="mb-3">
				<div class="input-group">
					<input type="text" name="search" value="@Model.SearchQuery"
						   class="form-control bg-dark text-white border-secondary"
						   placeholder="Search flights..." />
					<button class="btn btn-outline-info" type="submit">Search</button>
				</div>
			</form>

			<table class="table table-dark table-hover">
				<thead>
					<tr>
						<th>Flight No.</th>
						<th>Date</th>
						<th>Destination</th>
						<th>Runway</th>
						<th>Gate</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var flight in Model.Flights)
					{
						<tr>
							<td class="fw-bold">@flight.FlightNumber</td>
							<td>@flight.DateText</td>
							<td>@flight.DestinationText</td>
							<td>@flight.RunwayText</td>
							<td>@flight.GateText</td>
							<td>
								<a asp-action="OpenCrewManagement" asp-route-flightId="@flight.Id" class="btn btn-sm btn-outline-warning">Crew</a>
								<form asp-action="RemoveFlight" asp-route-flightId="@flight.Id" method="post" class="d-inline">
									<button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete flight?')">Delete</button>
								</form>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
</div>
