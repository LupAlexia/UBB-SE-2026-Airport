@model AirportApp.ClassLibrary.Entity.Domain.FAQEntry

@{
    ViewData["Title"] = "Details";
}
<partial name="_UpperBar" />
<div class="faq-page">

<style>
    .faq-page { font-size: 1.12rem; }
    .faq-page .btn { font-size: 1.06rem; padding-top: .45rem; padding-bottom: .45rem; }
    .faq-page .form-control { font-size: 1rem; }
    .faq-actions { display: flex; gap: .6rem; align-items: center; white-space: nowrap; }
    .faq-actions a { display: inline-block; }
</style>

<div class="mb-4">
    <h1 class="h3">Details</h1>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title">FAQ</h5>
        <hr />
        <dl class="row g-2">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Question)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Question)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Answer)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Answer)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class = "col-sm-10">
            @Model.Category
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ViewCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ViewCount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.HelpfulVotesCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.HelpfulVotesCount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NotHelpfulVotesCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NotHelpfulVotesCount)
        </dd>
        </dl>
    </div>
</div>

<div class="my-3">
    @if (User.IsInRole("Customer"))
    {
    <div class="d-flex gap-2">
        <form asp-action="IncrementHelpfulVotes" asp-route-id="@Model.Id" method="post" class="m-0">
            <button type="submit" class="btn btn-success">Helpful</button>
        </form>

        <form asp-action="IncrementNotHelpfulVotes" asp-route-id="@Model.Id" method="post" class="m-0">
            <button type="submit" class="btn btn-outline-secondary">Not Helpful</button>
        </form>
    </div>
    }
</div>
<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
</div>

