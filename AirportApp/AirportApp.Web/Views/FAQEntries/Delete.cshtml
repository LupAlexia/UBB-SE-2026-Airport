@model AirportApp.ClassLibrary.Entity.Domain.FAQEntry

@{
    ViewData["Title"] = "Delete";
}
<partial name="_UpperBar" />
<div class="faq-page">

<style>
    .faq-page { font-size: 1.12rem; }
    .faq-page .btn { font-size: 1.06rem; padding-top: .45rem; padding-bottom: .45rem; }
    .faq-page .form-control { font-size: 1rem; }
    .faq-actions { display: flex; gap: .6rem; align-items: center; white-space: nowrap; }
    .faq-actions a { display: inline-block; }
</style>

    <div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h3 class="mb-0">Delete FAQ</h3>
    </div>
    <div class="card-body">
        <p class="mb-2 fw-semibold">Are you sure you want to delete this?</p>
        <hr />
        <dl class="row g-2">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Question)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Question)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Answer)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Answer)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Category)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ViewCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ViewCount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.HelpfulVotesCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.HelpfulVotesCount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NotHelpfulVotesCount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NotHelpfulVotesCount)
        </dd>
        </dl>
        <div class="mt-3 d-flex gap-2">
            <form asp-action="Delete" class="m-0">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>

