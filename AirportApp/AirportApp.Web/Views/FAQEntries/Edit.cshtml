@model AirportApp.ClassLibrary.Entity.Domain.FAQEntry

@{
    ViewData["Title"] = "Edit";
}
<partial name="_UpperBar" />
<div class="faq-page">

<style>
    .faq-page { font-size: 1.12rem; }
    .faq-page .btn { font-size: 1.06rem; padding-top: .45rem; padding-bottom: .45rem; }
    .faq-page .form-control { font-size: 1rem; }
    .faq-actions { display: flex; gap: .6rem; align-items: center; white-space: nowrap; }
    .faq-actions a { display: inline-block; }
</style>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">Edit FAQ Entry</h3>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="Question" class="form-label"></label>
                        <input asp-for="Question" class="form-control" />
                        <span asp-validation-for="Question" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Answer" class="form-label"></label>
                        <input asp-for="Answer" class="form-control" />
                        <span asp-validation-for="Answer" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Category" class="form-label"></label>
                        <select asp-for="Category" class="form-control" asp-items="Html.GetEnumSelectList<AirportApp.ClassLibrary.Entity.Domain.FAQCategoryEnum>()"></select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>
                    <input type="hidden" asp-for="ViewCount" />
                    <input type="hidden" asp-for="HelpfulVotesCount" />
                    <input type="hidden" asp-for="NotHelpfulVotesCount" />
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</div>

