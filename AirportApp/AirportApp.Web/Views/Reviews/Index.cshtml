@model AirportApp.Web.Models.Reviews.EmployeeReviewsIndexViewModel

@{
    ViewData["Title"] = "Customer Reviews";
}

<style>
    .reviews-shell {
        background: linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 28px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.10);
        overflow: hidden;
    }

    .reviews-hero {
        background: radial-gradient(circle at top right, rgba(0, 120, 212, 0.18), transparent 35%), linear-gradient(135deg, #ffffff 0%, #f5f9ff 100%);
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }

    .reviews-badge {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .4rem .8rem;
        border-radius: 999px;
        background: #dff4ff;
        color: #0078d4;
        font-size: .9rem;
        font-weight: 600;
    }

    .review-card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 22px;
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
    }

    .stats-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 22px;
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
    }

    .metric-label {
        color: #64748b;
        font-size: .82rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        font-weight: 700;
    }

    .metric-value {
        color: #0f172a;
        font-size: 2.1rem;
        font-weight: 800;
        line-height: 1;
    }

    .avatar-badge {
        width: 52px;
        height: 52px;
        border-radius: 999px;
        background: linear-gradient(135deg, #0078d4 0%, #0ea5e9 100%);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .rating-label {
        font-size: .8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .03em;
        color: #64748b;
    }
</style>

<div class="reviews-shell">
    <div class="reviews-hero p-4 p-md-5">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div class="d-flex flex-column gap-3">
                <span class="reviews-badge">Employee view</span>
                <div>
                    <h1 class="display-6 fw-semibold mb-2">Customer Reviews</h1>
                    <p class="text-body-secondary mb-0" style="max-width: 52rem;">
                        Review customer feedback and track the average satisfaction across all submissions.
                    </p>
                </div>
            </div>
            <div class="text-md-end">
                <div class="text-uppercase text-body-secondary small fw-semibold">Read-only review board</div>
                <div class="fs-5 fw-semibold text-primary">Average across all reviews</div>
                <div class="mt-3">
                    <a asp-controller="Dashboard" asp-action="RedirectUser" class="btn btn-outline-primary btn-sm px-3">
                        Back to dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="p-4 p-md-5">
        <div class="stats-card p-4 p-md-5 mb-4">
            <div class="row g-4 align-items-stretch">
                <div class="col-12 col-md-4 col-xl-3">
                    <div class="h-100 p-3 p-lg-4 rounded-4" style="background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%); color: #fff;">
                        <div class="metric-label" style="color: rgba(255,255,255,0.72);">Total reviews</div>
                        <div class="metric-value text-white">@Model.TotalReviews</div>
                        <div class="mt-3 small" style="color: rgba(255,255,255,0.8);">All customer feedback collected so far</div>
                    </div>
                </div>

                <div class="col-12 col-md-8 col-xl-9">
                    <div class="row g-3 g-xl-4">
                        <div class="col-6 col-xl-3">
                            <div class="p-3 rounded-4 bg-white h-100 border">
                                <div class="metric-label">Overall average</div>
                                <div class="metric-value">@Model.AverageOverallRating.ToString("0.0")</div>
                                <div class="text-body-secondary small">Average of all review scores</div>
                            </div>
                        </div>

                        <div class="col-6 col-xl-3">
                            <div class="p-3 rounded-4 bg-white h-100 border">
                                <div class="metric-label">Duty free</div>
                                <div class="metric-value">@Model.AverageDutyFree.ToString("0.0")</div>
                                <div class="text-body-secondary small">Shop experience</div>
                            </div>
                        </div>

                        <div class="col-6 col-xl-3">
                            <div class="p-3 rounded-4 bg-white h-100 border">
                                <div class="metric-label">Flight experience</div>
                                <div class="metric-value">@Model.AverageFlightExperience.ToString("0.0")</div>
                                <div class="text-body-secondary small">Boarding and travel flow</div>
                            </div>
                        </div>

                        <div class="col-6 col-xl-3">
                            <div class="p-3 rounded-4 bg-white h-100 border">
                                <div class="metric-label">Cleanliness</div>
                                <div class="metric-value">@Model.AverageCleanliness.ToString("0.0")</div>
                                <div class="text-body-secondary small">Facility and terminal condition</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Reviews.Count == 0)
        {
            <div class="review-card p-5 text-center">
                <h2 class="h4 fw-semibold mb-2">No reviews yet</h2>
                <p class="text-body-secondary mb-0">Once customers submit feedback, the review board will appear here.</p>
            </div>
        }
        else
        {
            <div class="d-grid gap-4">
                @foreach (var item in Model.Reviews)
                {
                    var avatarText = string.IsNullOrWhiteSpace(item.userName) ? "A" : item.userName.Trim()[0].ToString().ToUpperInvariant();

                    <div class="review-card p-4 p-md-5">
                        <div class="d-flex flex-column flex-md-row gap-4">
                            <div class="avatar-badge">@avatarText</div>

                            <div class="flex-grow-1">
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3">
                                    <div>
                                        <div class="fw-semibold fs-5">@item.userName</div>
                                        <div class="text-body-secondary small">Review #@item.reviewId · User #@item.userId</div>
                                    </div>

                                    <div class="text-md-end">
                                        <div class="rating-label mb-1">Overall rating</div>
                                        <div class="fs-4 fw-bold text-primary">@item.overallRating.ToString("0.0") / 5</div>
                                    </div>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-12 col-md-3">
                                        <div class="p-3 rounded-4 bg-light border h-100">
                                            <div class="rating-label">Duty free</div>
                                            <div class="fs-5 fw-semibold">@item.dutyFreeRating / 5</div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <div class="p-3 rounded-4 bg-light border h-100">
                                            <div class="rating-label">Flight experience</div>
                                            <div class="fs-5 fw-semibold">@item.flightExperienceRating / 5</div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <div class="p-3 rounded-4 bg-light border h-100">
                                            <div class="rating-label">Staff friendliness</div>
                                            <div class="fs-5 fw-semibold">@item.staffFriendlinessRating / 5</div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <div class="p-3 rounded-4 bg-light border h-100">
                                            <div class="rating-label">Cleanliness</div>
                                            <div class="fs-5 fw-semibold">@item.cleanlinessRating / 5</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="p-4 rounded-4" style="background: #f8fbff; border: 1px solid rgba(15, 23, 42, 0.08);">
                                    <div class="text-body-secondary small fw-semibold mb-2">Customer message</div>
                                    <div class="fst-italic text-body">@item.message</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

