@using System.Security.Claims

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@if (User.Identity?.IsAuthenticated == true)
{
    var isClientView = User.IsInRole("Customer");
    var isEmployee = User.IsInRole("Employee");
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0";

    <nav class="navbar navbar-expand-md border-bottom bg-white px-4 py-0 mb-4" style="height: 70px; border-color: #EDEBE9 !important;">
        <div class="container-fluid d-flex align-items-center justify-content-between">

            <a asp-controller="Dashboard" asp-action="RedirectUser" class="text-decoration-none d-flex align-items-center gap-2">
                <img src="/Assets/CloudSpritzersLogo.png" alt="Logo" style="width: 50px; height: 50px; object-fit: contain;" />
                <span class="fw-bold" style="font-size: 22px; color: #0078D4; font-family: 'Segoe UI', sans-serif;">CloudSpritzers</span>
            </a>

            <div class="d-flex align-items-center gap-4">

                @if (isClientView)
                {
                    <a asp-controller="ChatBot" asp-action="Index" class="text-decoration-none d-flex align-items-center gap-2 px-2 py-1" style="color: #050B14; font-size: 15px; font-family: 'Segoe UI', sans-serif;">
                        <i class="bi bi-chat-left-text" style="color: #00A3A3; font-size: 18px;"></i> Chat
                    </a>
                }

                <a asp-controller="FAQEntries" asp-action="Index" class="text-decoration-none d-flex align-items-center gap-2 px-2 py-1" style="color: #050B14; font-size: 15px; font-family: 'Segoe UI', sans-serif;">
                    <i class="bi bi-question-lg" style="color: #00A3A3; font-size: 20px; font-weight: bold;"></i> FAQ
                </a>

                @if (isClientView)
                {
                    <a asp-controller="ComplaintTickets" asp-action="Index" class="text-decoration-none d-flex align-items-center gap-2 px-2 py-1" style="color: #050B14; font-size: 15px; font-family: 'Segoe UI', sans-serif;">
                        <i class="bi bi-card-text" style="color: #00A3A3; font-size: 18px;"></i> Complaint Tickets
                    </a>
                }
                else if (isEmployee)
                {
                    <a asp-controller="ComplaintTickets" asp-action="Index" class="text-decoration-none d-flex align-items-center gap-2 px-2 py-1" style="color: #050B14; font-size: 15px; font-family: 'Segoe UI', sans-serif;">
                        <i class="bi bi-card-text" style="color: #00A3A3; font-size: 18px;"></i> Complaint Tickets
                    </a>
                }

                @if (isClientView)
                {
                    <a asp-controller="Reviews" asp-action="Create" class="text-decoration-none d-flex align-items-center gap-2 px-2 py-1" style="color: #050B14; font-size: 15px; font-family: 'Segoe UI', sans-serif;">
                        <i class="bi bi-star" style="color: #00A3A3; font-size: 18px;"></i> Reviews
                    </a>
                }
                else if (isEmployee)
                {
                    <a asp-controller="Reviews" asp-action="Index" class="text-decoration-none d-flex align-items-center gap-2 px-2 py-1" style="color: #050B14; font-size: 15px; font-family: 'Segoe UI', sans-serif;">
                        <i class="bi bi-star" style="color: #00A3A3; font-size: 18px;"></i> Reviews
                    </a>
                }

                <a asp-controller="Dashboard" asp-action="RedirectUser" class="text-decoration-none d-flex align-items-center gap-2 px-2 py-1" style="color: #050B14; font-size: 15px; font-family: 'Segoe UI', sans-serif;">
                    <i class="bi bi-house" style="color: #00A3A3; font-size: 18px;"></i> Home
                </a>
            </div>

            <div class="d-flex flex-column align-items-center justify-content-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; background-color: #BCEEFA;">
                    <i class="bi bi-person" style="color: #00A3A3; font-size: 20px;"></i>
                </div>
                <span class="text-muted mt-1" style="font-size: 10px; font-family: 'Segoe UI', sans-serif;">ID: @userId</span>
            </div>

        </div>
    </nav>
}

