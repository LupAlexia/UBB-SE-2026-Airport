@{
    ViewData["Title"] = "Access denied";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-6">
        <div class="alert alert-warning border-0 shadow-sm p-4">
            <h1 class="h3 fw-semibold mb-2">Access denied</h1>
            <p class="mb-3">You are signed in, but your account does not have permission to open that page.</p>
            <a asp-controller="Auth" asp-action="ChooseRole" class="btn btn-warning">Choose another login</a>
        </div>
    </div>
</div>