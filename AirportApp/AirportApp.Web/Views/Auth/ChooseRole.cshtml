@{
    ViewData["Title"] = "Choose Role";
}

<div class="container-fluid vh-100 d-flex flex-column justify-content-center align-items-center" style="background-color: #0078D4; overflow: hidden; margin: 0; padding: 0;">

    <div class="text-center mb-4">
        <h1 class="fw-bold text-white m-0" style="font-size: 36px; font-family: 'Segoe UI', system-ui, sans-serif;">Welcome to Airport App!</h1>
        <p class="text-white mt-2 mb-0" style="font-size: 16px; opacity: 0.9;">How can we assist you today?</p>
    </div>

    <div class="d-flex flex-column flex-md-row gap-4 justify-content-center align-items-center flex-wrap">

        <a asp-action="EnterId" asp-route-role="Customer" class="text-decoration-none text-start">
            <div class="card p-3 text-center border-0 shadow-lg"
                 style="width: 220px; height: 180px; border-radius: 12px; background-color: #FFFFFF; transition: transform 0.2s, background-color 0.2s; cursor: pointer;">
                <div class="d-flex flex-column align-items-center justify-content-center h-100">
                    <h2 class="fw-semibold mb-2" style="font-size: 18px; color: #201F1E; font-family: 'Segoe UI', sans-serif;">Customer</h2>
                    <p class="mb-0" style="font-size: 12px; color: #605E5C; line-height: 1.4; padding: 0 5px;">
                        Flight tickets, customer support, and duty free shopping.
                    </p>
                </div>
            </div>
        </a>

        <a asp-action="EnterId" asp-route-role="Admin" class="text-decoration-none text-start">
            <div class="card p-3 text-center border-0 shadow-lg"
                 style="width: 220px; height: 180px; border-radius: 12px; background-color: #FFFFFF; transition: transform 0.2s, background-color 0.2s; cursor: pointer;">
                <div class="d-flex flex-column align-items-center justify-content-center h-100">
                    <h2 class="fw-semibold mb-2" style="font-size: 18px; color: #201F1E; font-family: 'Segoe UI', sans-serif;">Admin</h2>
                    <p class="mb-0" style="font-size: 12px; color: #605E5C; line-height: 1.4; padding: 0 5px;">
                        Manage FAQ, tickets, reviews, employees, routes, and gates.
                    </p>
                </div>
            </div>
        </a>

        <a asp-action="EnterId" asp-route-role="Manager" class="text-decoration-none text-start">
            <div class="card p-3 text-center border-0 shadow-lg"
                 style="width: 220px; height: 180px; border-radius: 12px; background-color: #FFFFFF; transition: transform 0.2s, background-color 0.2s; cursor: pointer;">
                <div class="d-flex flex-column align-items-center justify-content-center h-100">
                    <h2 class="fw-semibold mb-2" style="font-size: 18px; color: #201F1E; font-family: 'Segoe UI', sans-serif;">Manager</h2>
                    <p class="mb-0" style="font-size: 12px; color: #605E5C; line-height: 1.4; padding: 0 5px;">
                        Flight company manager - add and manage flights.
                    </p>
                </div>
            </div>
        </a>

        <a asp-action="EnterId" asp-route-role="Employee" class="text-decoration-none text-start">
            <div class="card p-3 text-center border-0 shadow-lg"
                 style="width: 220px; height: 180px; border-radius: 12px; background-color: #FFFFFF; transition: transform 0.2s, background-color 0.2s; cursor: pointer;">
                <div class="d-flex flex-column align-items-center justify-content-center h-100">
                    <h2 class="fw-semibold mb-2" style="font-size: 18px; color: #201F1E; font-family: 'Segoe UI', sans-serif;">Employee</h2>
                    <p class="mb-0" style="font-size: 12px; color: #605E5C; line-height: 1.4; padding: 0 5px;">
                        Flight crew - view schedule and assigned flights.
                    </p>
                </div>
            </div>
        </a>

    </div>
</div>