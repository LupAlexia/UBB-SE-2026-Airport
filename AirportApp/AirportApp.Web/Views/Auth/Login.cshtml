@model AirportApp.Web.Models.Auth.CustomerLoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Flight Security Access";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #ffffff;
        }

        .login-input {
            border: none;
            border-bottom: 1px solid #cccccc;
            border-radius: 0;
            padding: 10px 0;
            box-shadow: none;
            outline: none;
            width: 300px;
        }

        .login-input:focus {
            border-bottom-color: #2bb8c0;
            box-shadow: none;
        }

        .login-btn {
            background-color: #2bb8c0;
            color: #ffffff;
            width: 300px;
            height: 44px;
            border-radius: 8px;
            font-weight: bold;
            font-size: 15px;
            border: none;
        }

        .login-btn:hover {
            background-color: #23a0a8;
            color: #ffffff;
        }
    </style>
</head>
<body>
    <div class="d-flex flex-column align-items-center justify-content-center vh-100">

        <h1 class="fw-bold mb-3" style="font-size: 32px; color: #2bb8c0;">Flight Security Access</h1>
        <p class="text-muted mb-4 text-center" style="max-width: 500px;">
            To protect your flight details and personal data, please complete this quick security verification.
        </p>

        <form asp-action="Login" asp-controller="Auth" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="d-flex flex-column align-items-center gap-3">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small text-center" style="max-width: 300px;"></div>

            <input asp-for="Email"
                   class="login-input form-control"
                   placeholder="Email"
                   autocomplete="email"
                   autofocus />
            <span asp-validation-for="Email" class="text-danger small" style="width: 300px;"></span>

            <input asp-for="Password"
                   type="password"
                   class="login-input form-control"
                   placeholder="Password"
                   autocomplete="current-password" />
            <span asp-validation-for="Password" class="text-danger small" style="width: 300px;"></span>

            <button type="submit" class="login-btn mt-2">Sign In</button>
        </form>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

