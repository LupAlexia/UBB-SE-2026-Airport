@{
    ViewData["Title"] = "Enter Your ID";
    var role = ViewData["Role"]?.ToString();
}

<div class="container-fluid min-vh-100 d-flex flex-column justify-content-center align-items-center position-relative" style="background-color: #0078D4;">

    <div class="card border-0 shadow-lg p-4" style="width: 350px; border-radius: 12px; background-color: #FFFFFF;">

        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
             style="width: 48px; height: 48px; background-color: #0078D4;">
            <span style="color: #FFFFFF; font-size: 20px;">💬</span>
        </div>

        <h2 class="fw-semibold text-center mb-1" style="font-size: 20px; color: #201F1E; font-family: 'Segoe UI', sans-serif;">
            Welcome to Assistance Chat
        </h2>
        <p class="text-center mb-4" style="font-size: 12px; color: #605E5C; line-height: 1.3;">
            Please enter your User ID to continue as a @role
        </p>

        <form asp-action="EnterId" method="post" class="text-start">
            @Html.AntiForgeryToken()
            <div class="text-danger small mb-3 text-center" asp-validation-summary="ModelOnly"></div>

            <input type="hidden" name="role" value="@role" />

            <div class="mb-3 d-flex flex-column gap-1">
                <label class="fw-normal" style="font-size: 12px; color: #605E5C;">User ID</label>
                <input type="text" name="identificationId" class="form-control px-3"
                       style="height: 36px; font-size: 14px; background-color: #FFFFFF; border: 1px solid #A19F9D; border-radius: 4px; color: #201F1E;"
                       placeholder="Enter your ID" required autofocus />
            </div>

            <button type="submit" class="btn w-100 fw-normal text-white d-flex align-items-center justify-content-center"
                    style="height: 40px; background-color: #0078D4; border-radius: 6px; font-size: 14px; border: none;">
                Continue
            </button>
        </form>
    </div>

    <div class="position-absolute start-0 bottom-0 m-4">
        <a asp-action="ChooseRole" class="text-decoration-none d-flex align-items-center gap-2" style="border: none; background: transparent;">
            <span style="color: #FFFFFF; font-size: 16px;">←</span>
            <span class="fw-semibold" style="color: #FFFFFF; font-size: 14px; font-family: 'Segoe UI', sans-serif;">Back to Welcome</span>
        </a>
    </div>
</div>
