@model string

@{
    bool isSearchActive = string.Equals(Model, "Search", StringComparison.OrdinalIgnoreCase);
    bool isTicketsActive = string.Equals(Model, "MyTickets", StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex align-items-center justify-content-between gap-3 flex-wrap mb-4 pb-3 border-bottom">
    <div>
        <h1 class="fw-bold text-dark mb-1" style="font-size: 28px;">Flights</h1>
        <p class="text-muted mb-0">Search flights or review your booked tickets.</p>
    </div>

    <div class="btn-group" role="tablist" aria-label="Flight dashboard navigation">
        <a asp-controller="FlightTickets"
           asp-action="Search"
           class="btn @(isSearchActive ? "btn-info text-white" : "btn-outline-info")">
            Search
        </a>
        <a asp-controller="FlightTickets"
           asp-action="MyTickets"
           class="btn @(isTicketsActive ? "btn-info text-white" : "btn-outline-info")">
            My Tickets
        </a>
    </div>
</div>