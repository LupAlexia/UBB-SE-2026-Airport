@model IEnumerable<AirportApp.ClassLibrary.Entity.Domain.FlightTicket>

@{
    ViewData["Title"] = "Flight Tickets";
    var ticketFilters = ViewBag.TicketFilters as IEnumerable<string> ?? new[] { "Upcoming", "Past" };
    var selectedTicketFilter = ViewBag.SelectedTicketFilter as string ?? "Upcoming";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="fw-bold text-dark mb-1" style="font-size: 28px;">My Flight Tickets</h1>
        @if (ViewBag.CurrentUserId != null)
        {
            <p class="text-muted mb-0">Manage your active bookings, cancellations, and generate PDFs.</p>
        }
    </div>
    <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
        <label for="ticketFilter" class="form-label mb-0 text-muted">Show:</label>
        <select id="ticketFilter" name="ticketFilter" class="form-select" style="width: 150px;" onchange="this.form.submit()">
            @foreach (var filter in ticketFilters)
            {
                if (string.Equals(filter, selectedTicketFilter, StringComparison.OrdinalIgnoreCase))
                {
                    <option value="@filter" selected>@filter</option>
                }
                else
                {
                    <option value="@filter">@filter</option>
                }
            }
        </select>
    </form>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                Flight
            </th>
            <th>
                Date
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Seat)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PassengerFirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PassengerLastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PassengerEmail)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PassengerPhone)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @(item.Flight?.FlightNumber ?? "N/A")
            </td>
            <td>
                @(item.Flight?.Date.ToString("g") ?? "N/A")
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Seat)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PassengerFirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PassengerLastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PassengerEmail)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PassengerPhone)
            </td>
            <td>
                @if (item.Status != "Cancelled" && item.Status != "Canceled")
                {
                    <a asp-action="Cancel" asp-route-id="@item.Id" class="text-danger">Cancel</a> <span>|</span>
                }
                <a asp-action="DownloadPdf" asp-route-id="@item.Id" target="_blank">Download PDF</a>
            </td>
        </tr>
}
    </tbody>
</table>

