@model AirportApp.Web.Models.DutyFree.CartViewModel
@{
    ViewData["Title"] = "My Cart";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="DutyFree" asp-action="Index">Shops</a>
        </li>
        <li class="breadcrumb-item active">My Cart</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-4">
    <h1 class="me-auto" style="color: #00bcd4;">My Cart</h1>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        <p class="mb-0">Your cart is empty. <a asp-controller="DutyFree" asp-action="Index">Browse duty-free shops</a> to add items.</p>
    </div>
}
else
{
    @if (Model.HasActiveReservation)
    {
        <div class="alert alert-success d-flex align-items-center justify-content-between mb-4">
            <span>
                <strong>Reservation active!</strong> Your cart items are reserved (Reservation #@Model.ActiveReservationId).
            </span>
            <form asp-controller="DutyFreeCart" asp-action="CancelReservation" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="reservationId" value="@Model.ActiveReservationId" />
                <button type="submit" class="btn btn-outline-danger btn-sm">Cancel Reservation</button>
            </form>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 60px;"></th>
                        <th>Item</th>
                        <th class="text-center">Unit Price</th>
                        <th class="text-center" style="width: 160px;">Quantity</th>
                        <th class="text-end">Subtotal</th>
                        <th style="width: 60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var itemVm in Model.Items)
                    {
                        var item = itemVm.CartItem;
                        var subtotal = item.GetTotalPrice();

                        <tr>
                            <td class="ps-3">
                                @if (!string.IsNullOrEmpty(item.ShopItem.Photo))
                                {
                                    <img src="@item.ShopItem.Photo" alt="@item.ShopItem.Name"
                                         class="rounded" style="width: 48px; height: 48px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-secondary rounded d-flex align-items-center justify-content-center"
                                         style="width: 48px; height: 48px;">
                                        <span class="text-white small">N/A</span>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@item.ShopItem.Name</div>
                                <div class="text-muted small">@item.ShopItem.Shop?.Name</div>
                            </td>
                            <td class="text-center">@item.ShopItem.Price.ToString("C")</td>
                            <td class="text-center">
                                <form asp-controller="DutyFreeCart" asp-action="UpdateQuantity"
                                      method="post" class="d-flex align-items-center justify-content-center gap-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartId" value="@Model.CartId" />
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <input type="number" name="quantity" value="@item.Quantity"
                                           min="1" class="form-control form-control-sm text-center"
                                           style="width: 65px;" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">â†µ</button>
                                </form>
                            </td>
                            <td class="text-end fw-semibold">@subtotal.ToString("C")</td>
                            <td class="text-center pe-3">
                                <form asp-controller="DutyFreeCart" asp-action="RemoveItem" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartId" value="@Model.CartId" />
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            title="Remove item"
                                            onclick="return confirm('Remove this item from your cart?');">
                                        &times;
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <a asp-controller="DutyFree" asp-action="Index" class="btn btn-outline-secondary">
            &larr; Continue Shopping
        </a>

        <div class="d-flex align-items-center gap-4">
            <div class="fs-5">
                <span class="text-muted">Total:</span>
                <strong class="ms-2" style="color: #00bcd4;">@Model.Total.ToString("C")</strong>
            </div>

            @if (!Model.HasActiveReservation)
            {
                <form asp-controller="DutyFreeCart" asp-action="Reserve" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="cartId" value="@Model.CartId" />
                    <button type="submit" class="btn btn-primary">Reserve Cart</button>
                </form>
            }
        </div>
    </div>
}

