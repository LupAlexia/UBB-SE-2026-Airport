@model AirportApp.Web.Models.DutyFree.ItemDetailsViewModel
@{
	Layout = "_Layout";
    ViewData["Title"] = Model.Item.Name;
}

<div class="d-flex align-items-start gap-3 mb-3">
    <nav aria-label="breadcrumb" class="me-auto">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="DutyFree" asp-action="Index">Shops</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="DutyFreeShopItems" asp-action="Index" asp-route-shopId="@Model.Shop.Id">@Model.Shop.Name</a>
            </li>
            <li class="breadcrumb-item active">@Model.Item.Name</li>
        </ol>
    </nav>

    @if (!Model.IsManager)
    {
        <a asp-controller="DutyFreeCart" asp-action="Index" class="btn btn-primary">
            Cart
        </a>
    }
</div>

<div class="card shadow-sm">
    <div class="row g-0">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.Item.Photo))
            {
                <img src="@Model.Item.Photo" class="img-fluid rounded-start" alt="@Model.Item.Name" />
            }
            else
            {
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded-start" style="min-height: 300px;">
                    <span>No image available</span>
                </div>
            }
        </div>
        <div class="col-md-8">
            <div class="card-body">
                <h2 class="card-title">@Model.Item.Name</h2>
                <h4 class="text-success">@Model.Item.Price.ToString("C")</h4>
                <p class="text-muted">In stock: @Model.Item.Quantity</p>
                <p class="card-text">@Model.Item.Description</p>
                <p class="text-muted">
                    Shop: <strong>@Model.Shop.Name</strong> &mdash; @Model.Shop.Type
                </p>
                <hr />

                @if (Model.IsManager)
                {
                    <div class="mt-3">
                        <a asp-controller="DutyFreeShopItems" asp-action="EditItemForm"
                           asp-route-id="@Model.Item.Id" class="btn btn-warning">Edit Item</a>
                    </div>
                }
                else if (Model.ItemAlreadyInCart)
                {
                    <div class="alert alert-info">
                        This item is already in your cart.
                        <a asp-controller="DutyFreeCart" asp-action="Index" class="alert-link">View cart</a>
                    </div>
                }
                else
                {
                    <form asp-controller="DutyFreeItemDetails" asp-action="AddToCart" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="itemId" value="@Model.Item.Id" />
                        <input type="hidden" name="cartId" value="@Model.CartId" />
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <label for="quantity">Quantity:</label>
                            <input type="number" id="quantity" name="quantity" value="@Model.QuantityToAdd"
                                   min="1" max="@Model.Item.Quantity" class="form-control" style="width: 80px;" />
                        </div>
                        <button type="submit" class="btn btn-primary">Add to Cart</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="DutyFreeShopItems" asp-action="Index"
       asp-route-shopId="@Model.Shop.Id" class="btn btn-outline-secondary">
        &larr; Back to Shop
    </a>
</div>

