@using AirportApp.Web.Models.DutyFree
@model ShopListViewModel

@{
    ViewData["Title"] = "DutyFree Shops";
}

<style>
    .brand-color-text { color: #2bb8c0 !important; }
    .brand-color-bg { background-color: #2bb8c0 !important; border-color: #2bb8c0 !important; }
    .brand-color-bg:hover { background-color: #219198 !important; }
    .shop-card {
        min-width: 300px;
        background-color: #f5f5f5;
        border-radius: 12px;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .shop-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
</style>

<div class="container-fluid py-4 px-md-5" style="background-color: #F9FAFB; min-height: 90vh;">
    
    <div class="row align-items-center mb-4 pb-3 border-bottom">
        <div class="col-12 col-md-auto mb-2 mb-md-0">
            <h1 class="fw-semibold display-6 brand-color-text m-0">DutyFree Shops</h1>
        </div>
        
        <div class="col-12 col-md mx-md-4 mb-2 mb-md-0">
            <form method="get" action="/DutyFree/Index" class="d-flex" style="max-width: 500px;">
                <input type="text" 
                       name="search" 
                       value="@Model.SearchQuery" 
                       class="form-control rounded-3 border-secondary-subtle py-2" 
                       placeholder="Search shops or categories..." />
                <button type="submit" class="btn btn-outline-secondary ms-2 rounded-3"><i class="bi bi-search"></i> Search</button>
            </form>
        </div>

        <div class="col-auto ms-auto">
            @if (Model.UserRole.ToString() == "Client")
            {
                <a asp-controller="DutyFreeCart" asp-action="Index"
                   class="btn brand-color-bg text-white px-3 py-2 rounded-2">
                    <i class="bi bi-cart"></i>
                </a>
            }
        </div>
    </div>

    <div class="row align-items-center justify-content-between mb-4">
        <div class="col-auto">
            @if (Model.UserRole.ToString() == "Manager" || Model.UserRole.ToString() == "Admin")
            {
                <button type="button" 
                        class="btn brand-color-bg text-white fw-medium px-4 py-2 shadow-sm" 
                        data-bs-toggle="collapse" 
                        data-bs-target="#addShopCollapseBlock">
                    + Add Shop
                </button>
            }
        </div>
        
        <div class="col-auto d-flex align-items-center gap-2">
            <span class="text-secondary opacity-75 small">Sort by:</span>
            <select class="form-select border-secondary-subtle shadow-sm" id="SortComboBox" style="width: 220px;">
                <option value="None">None</option>
                <option value="Name">Shop Name</option>
                <option value="Reviews">Reviews</option>
            </select>
        </div>
    </div>

    <div class="collapse mb-4" id="addShopCollapseBlock">
        <div class="card card-body bg-white border-0 shadow-sm p-4 rounded-3">
            <h5 class="card-title fw-semibold mb-3">Register a New Shop</h5>
            <form method="post" action="/DutyFree/AddShop">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-medium">Shop Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="Enter shop name" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-medium">Shop Type / Category</label>
                        <input type="text" name="Type" class="form-control" placeholder="e.g., Perfume, Alcohol, Souvenirs" required />
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-light" data-bs-toggle="collapse" data-bs-target="#addShopCollapseBlock">Cancel</button>
                    <button type="submit" class="btn brand-color-bg text-white px-4">Save Shop</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4" id="ShopsGridView">
        
        @if (!Model.Shops.Any())
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted fs-5">No shops available matching your criteria.</p>
            </div>
        }
        else
        {
            @foreach (var shop in Model.Shops)
            {
                <div class="col">
                    <div class="shop-card p-4 h-100 d-flex flex-column justify-content-between border-0 shadow-sm">
                        <div>
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <h5 class="fw-semibold text-dark mb-1 fs-5 text-truncate" style="max-width: 180px;">
                                    @shop.Name
                                </h5>
                                
                                @if (Model.UserRole.ToString() == "Manager" || Model.UserRole.ToString() == "Admin")
                                {
                                    <div class="d-flex gap-1 shadow-sm rounded">
                                        <a href="/DutyFree/EditShopForm/@shop.Id" class="btn btn-white btn-sm border bg-white text-secondary px-2 py-1" title="Modify">
                                            <strong>?</strong>
                                        </a>
                                        
                                        <form method="post" action="/DutyFree/DeleteShop/@shop.Id" class="d-inline" onsubmit="return confirm('Delete this shop instance permanently?');">
											@Html.AntiForgeryToken()
											<button type="submit" class="btn btn-white btn-sm border bg-white text-danger px-2 py-1" title="Remove">
												<strong>-</strong>
											</button>
										</form>
                                    </div>
                                }
                            </div>
                            
                            <p class="text-muted small opacity-75 mt-1 m-0">@shop.Type</p>
                        </div>

                        <div class="mt-3">
                            <a asp-controller="DutyFreeShopItems"
                               asp-action="Index"
                               asp-route-shopId="@shop.Id"
                               class="btn btn-outline-secondary btn-sm">
                                View products
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

