@model AirportApp.Web.Models.AirportManagement.CompanyDashboardViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Company Dashboard";
}

@section Styles
{
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/company-representative.css" asp-append-version="true" />
}

<div class="topbar">
    <i class="bi bi-airplane-fill topbar-icon"></i>
    <span class="topbar-title">Flight Module</span>
</div>


<div class="page-wrap">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mb-3" role="alert">
            <strong>Flight could not be created.</strong>
            <div asp-validation-summary="All" class="mt-2"></div>
        </div>
    }

    <div class="flight-card">

        <!-- Header -->
        <div class="card-header-row">
            <span class="card-title">@Model.CompanyName's Flights</span>
            <button class="btn-add" id="openAddModal" title="Add Flight">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>

        <!-- Search -->
        <div class="search-wrap">
            <form method="get" asp-action="Index" id="searchForm">
                <input class="search-input"
                       type="text"
                       name="search"
                       value="@Model.SearchQuery"
                       placeholder="Search flights by flight number..."
                       id="searchInput" />
                <input type="hidden" name="companyId" value="@Model.CompanyId" />
            </form>
        </div>

        <!-- Table -->
        <table class="flight-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Flight No.</th>
                    <th>Date</th>
                    <th>Destination</th>
                    <th>Runway</th>
                    <th>Gate</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="flightTableBody">
                @if (!Model.Flights.Any())
                {
                    <tr>
                        <td colspan="7" class="no-flights">No flights found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var f in Model.Flights)
                    {
                        <tr>
                            <td class="td-id">@f.Id</td>
                            <td class="td-fnum">@f.FlightNumber</td>
                            <td class="td-date">@f.DateText</td>
                            <td>@f.DestinationText</td>
                            <td>@f.RunwayText</td>
                            <td>@f.GateText</td>
                            <td>
								<a asp-action="DeleteFlight"
								   asp-route-flightId="@f.Id"
								   class="btn btn-sm btn-outline-danger"
								   title="Delete flight">
									<i class="bi bi-trash"></i>
								</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>
</div>

<!-- add flight -->
<div class="modal-backdrop-custom @(ViewData.ModelState.IsValid ? string.Empty : "open")" id="addModal">
	<div class="modal-box">
		<div class="modal-title">Add Flight</div>

		<form method="post" asp-action="AddFlight" id="addFlightForm">
			@Html.AntiForgeryToken()
			<input type="hidden" asp-for="AddFlightForm.CompanyId" />

			<div class="form-grid">

				<!-- TYPE -->
				<div>
					<label asp-for="AddFlightForm.RouteType" class="form-label">Type</label>
					<select asp-for="AddFlightForm.RouteType" class="form-ctrl">
						<option value="">Arr / Dep</option>
						<option value="Arrival">Arrival</option>
						<option value="Departure">Departure</option>
					</select>
				</div>

				<!-- AIRPORT -->
				<div>
					<label asp-for="AddFlightForm.AirportId" class="form-label">Airport</label>
					<select asp-for="AddFlightForm.AirportId" class="form-ctrl">
						<option value="">Select Airport</option>
						@foreach (var airport in Model.AddFlightForm.Airports)
						{
							<option value="@airport.Id">@airport.Name</option>
						}
					</select>
					<span asp-validation-for="AddFlightForm.AirportId" class="text-danger small"></span>
				</div>

				<!-- DEP. TIME -->
				<div>
					<label class="form-label">Dep. Time</label>
					<div class="time-row">
						<input asp-for="AddFlightForm.DepartureHour" class="time-part" type="number" min="1" max="12" />
						<span class="time-sep">:</span>
						<input asp-for="AddFlightForm.DepartureMinute" class="time-part" type="number" min="0" max="59" />
						<select asp-for="AddFlightForm.DepartureAmPm" class="ampm-select">
							<option value="AM">AM</option>
							<option value="PM">PM</option>
						</select>
					</div>
				</div>

				<!-- ARR. TIME -->
				<div>
					<label class="form-label">Arr. Time</label>
					<div class="time-row">
						<input asp-for="AddFlightForm.ArrivalHour" class="time-part" type="number" min="1" max="12" />
						<span class="time-sep">:</span>
						<input asp-for="AddFlightForm.ArrivalMinute" class="time-part" type="number" min="0" max="59" />
						<select asp-for="AddFlightForm.ArrivalAmPm" class="ampm-select">
							<option value="AM">AM</option>
							<option value="PM">PM</option>
						</select>
					</div>
				</div>

				<!-- CAPACITY -->
				<div>
					<label asp-for="AddFlightForm.Capacity" class="form-label">Capacity</label>
					<input asp-for="AddFlightForm.Capacity" class="form-ctrl" placeholder="e.g. 180" />
					<span asp-validation-for="AddFlightForm.Capacity" class="text-danger small"></span>
				</div>

				<!-- RECURRENT CHECKBOX -->
				<div style="display:flex; align-items:flex-end; padding-bottom:.1rem;">
					<div class="check-wrap">
						<input asp-for="AddFlightForm.IsRecurrent" type="checkbox" id="recurrentCheck" />
						<label for="recurrentCheck">Recurrent Flight</label>
					</div>
				</div>

				<!-- DATE (single) -->
				<div id="singleDateWrap">
					<label asp-for="AddFlightForm.SingleDate" class="form-label">Date</label>
					<input asp-for="AddFlightForm.SingleDate" class="form-ctrl" type="date" />
				</div>

				<!-- GATE -->
				<div>
					<label asp-for="AddFlightForm.GateId" class="form-label">Gate</label>
					<select asp-for="AddFlightForm.GateId" class="form-ctrl">
						<option value="">Select Gate</option>
						@foreach (var gate in Model.AddFlightForm.Gates)
						{
							<option value="@gate.Id">@gate.Name</option>
						}
					</select>
					<span asp-validation-for="AddFlightForm.GateId" class="text-danger small"></span>
				</div>

				<!-- RUNWAY -->
				<div class="full">
					<label asp-for="AddFlightForm.RunwayId" class="form-label">Runway</label>
					<select asp-for="AddFlightForm.RunwayId" class="form-ctrl">
						<option value="">Select Runway</option>
						@foreach (var runway in Model.AddFlightForm.Runways)
						{
							<option value="@runway.Id">@runway.Name</option>
						}
					</select>
					<span asp-validation-for="AddFlightForm.RunwayId" class="text-danger small"></span>
				</div>

				<!-- RECURRENT SECTION -->
				<div id="recurrent-section" class="full">
					<div class="rec-grid">
						<div>
							<label asp-for="AddFlightForm.StartDate" class="form-label">Start Date</label>
							<input asp-for="AddFlightForm.StartDate" class="form-ctrl" type="date" />
						</div>
						<div>
							<label asp-for="AddFlightForm.EndDate" class="form-label">End Date</label>
							<input asp-for="AddFlightForm.EndDate" class="form-ctrl" type="date" />
						</div>
						<div class="full">
							<label asp-for="AddFlightForm.RecurrenceType" class="form-label">Recurrence Type</label>
							<select asp-for="AddFlightForm.RecurrenceType" class="form-ctrl">
								<option value="Daily">Daily</option>
								<option value="Weekly">Weekly</option>
								<option value="Custom">Custom</option>
							</select>
						</div>
						<div class="full" id="custom-days-wrap">
							<label asp-for="AddFlightForm.CustomDaysText" class="form-label">Interval (days)</label>
							<input asp-for="AddFlightForm.CustomDaysText" class="form-ctrl" type="number" min="1" />
						</div>
					</div>
				</div>
			</div>

			<div class="modal-footer-btns">
				<button type="submit" class="btn-save">Save Flight</button>
				<button type="button" class="btn-cancel" id="cancelAdd">Cancel</button>
			</div>
		</form>
	</div>
</div>

<!--delete-->
<div class="modal-backdrop-custom" id="deleteModal">
    <div class="modal-box confirm-box">
        <div class="modal-title">Delete Flight</div>
        <p id="deleteConfirmText">Are you sure you want to delete this flight?</p>
        <form method="post" asp-action="DeleteFlight" id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteFlightId" />
            <div class="modal-footer-btns">
                <button type="submit" class="btn-danger-confirm">Delete</button>
                <button type="button" class="btn-cancel" id="cancelDelete">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <script src="~/js/company-representative.js" asp-append-version="true"></script>
}


