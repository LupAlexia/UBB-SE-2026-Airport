@model AirportApp.ClassLibrary.Entity.Domain.FlightSummary
@{
	Layout = "_Layout";
	ViewData["Title"] = "Confirm Flight Deletion";
}

<div class="container d-flex justify-content-center align-items-center mt-5">
	<div class="card border-danger bg-slate shadow-lg" style="width: 550px; background-color: #1e293b;">
		<div class="card-header border-danger bg-danger bg-opacity-10 py-3">
			<h4 class="text-danger fw-bold mb-0">
				<i class="bi bi-exclamation-octagon-fill"></i> Confirm Deletion
			</h4>
		</div>
		<div class="card-body p-4 text-white">
			<p class="fs-5 mb-4">Are you absolutely sure you want to delete this flight?</p>

			<div class="bg-dark p-3 rounded border border-secondary mb-4">
				<div class="row mb-2">
					<div class="col-4 text-muted small fw-bold text-uppercase">Flight Number</div>
					<div class="col-8 fw-bold text-info">@Model.FlightNumber</div>
				</div>
				<div class="row mb-2">
					<div class="col-4 text-muted small fw-bold text-uppercase">Destination</div>
					<div class="col-8">@Model.DestinationText</div>
				</div>
				<div class="row">
					<div class="col-4 text-muted small fw-bold text-uppercase">Scheduled Date</div>
					<div class="col-8">@Model.DateText</div>
				</div>
			</div>

			<div class="alert alert-warning border-warning bg-warning bg-opacity-10 text-warning-emphasis small">
				<i class="bi bi-info-circle"></i> This action will permanently remove the flight and all crew assignments.
			</div>

			<form asp-action="DeleteFlight" method="post" class="mt-4">
				<input type="hidden" name="flightId" value="@Model.Id" />

				<div class="row g-2">
					<div class="col-6">
						<a asp-action="Index" class="btn btn-outline-secondary w-100">Cancel</a>
					</div>
					<div class="col-6">
						<button type="submit" class="btn btn-danger w-100 fw-bold">Delete Flight</button>
					</div>
				</div>
			</form>
		</div>
	</div>
</div>
