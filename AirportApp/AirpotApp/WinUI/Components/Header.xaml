<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AirportApp.WinUI.Components.Header"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CustomAccentBrush" Color="#2bb8c0"/>
    </UserControl.Resources>

    <Grid Margin="0,0,0,30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Content="&#xE72B;"
                FontFamily="Segoe MDL2 Assets"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource CustomAccentBrush}"
                Click="HomeButton_Click"/>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
            <FontIcon Glyph="&#xE709;"
                      FontSize="32"
                      Foreground="{StaticResource CustomAccentBrush}"
                      VerticalAlignment="Center"/>
            <TextBlock Text="Flight Module"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.ColumnSpan="3" BorderThickness="0,0,0,1" BorderBrush="#333333"
                VerticalAlignment="Bottom" Margin="0,0,0,-15"/>
    </Grid>
</UserControl>
