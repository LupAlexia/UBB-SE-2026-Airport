<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.Pages.AirportRootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PageBackgroundBrush}" Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            <TextBlock Text="Airport module"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{StaticResource PrimaryTextBrush}"/>
            <Button Content="Book a Flight"
                    Click="OpenAirportExperience_Click"
                    HorizontalAlignment="Stretch"
                    MinWidth="320"
                    Height="64"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    CornerRadius="10"/>
            <Button Content="Airport Management"
                    Click="OpenAirportManagement_Click"
                    HorizontalAlignment="Stretch"
                    MinWidth="320"
                    Height="64"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    CornerRadius="10"/>
        </StackPanel>
    </Grid>
</Page>
