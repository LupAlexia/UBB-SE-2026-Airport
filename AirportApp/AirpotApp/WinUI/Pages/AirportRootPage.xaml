<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.Pages.AirportRootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F0F4F8" Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock Text="Airport module"
                       HorizontalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <Button Content="Book a Flight"
                    Click="OpenAirportExperience_Click"
                    HorizontalAlignment="Center"
                    Background="#2BB8C0"
                    Foreground="White"
                    Padding="24,12"
                    CornerRadius="8"/>
            <Button Content="Airport Management"
                    Click="OpenAirportManagement_Click"
                    HorizontalAlignment="Center"
                    Background="#6366F1"
                    Foreground="White"
                    Padding="24,12"
                    CornerRadius="8"/>
        </StackPanel>
    </Grid>
</Page>
