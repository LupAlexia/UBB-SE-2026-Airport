<Page
    x:Class="AirportApp.WinUI.Pages.DutyFreeRootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F0F4F8" Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock Text="Duty-free module"
                       HorizontalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <Button Content="Open Duty-Free Experience"
                    Click="OpenDutyFreeExperience_Click"
                    HorizontalAlignment="Center"
                    Background="#F59E0B"
                    Foreground="White"
                    Padding="24,12"
                    CornerRadius="8"/>
        </StackPanel>
    </Grid>
</Page>
