<Page
    x:Class="AirportApp.WinUI.Pages.DutyFreeRootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource PageBackgroundBrush}" Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock Text="Duty-free module"
                       HorizontalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <Button Content="Open Duty-Free Experience"
                    Click="OpenDutyFreeExperience_Click"
                    HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
