<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource DarkBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="RoleCardStyle" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="MinHeight" Value="160"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,28"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="0">

            <TextBlock Text="Staff Portal"
                       FontSize="38"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Select your role to continue"
                       FontSize="15"
                       Foreground="{StaticResource DarkMutedTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,36"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel.Resources>
                    <ResourceDictionary>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource CardBackgroundColor}"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource PrimaryTextColor}"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource PrimaryColor}"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource PageBackgroundColor}"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource PrimaryTextColor}"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource PrimaryColor}"/>
                    </ResourceDictionary>
                </StackPanel.Resources>

                <Button Style="{StaticResource RoleCardStyle}"
                        Background="{StaticResource IndigoTintBrush}"
                        Command="{x:Bind ViewModel.NavigateToAdminCommand}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Admin"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource IndigoBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Manage FAQ, tickets, reviews, employees, routes, and gates."
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="172"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource RoleCardStyle}"
                        Background="{StaticResource TealTintBrush}"
                        Command="{x:Bind ViewModel.NavigateToCompanyCommand}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Manager"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Flight company manager – add and manage flights."
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="172"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource RoleCardStyle}"
                        Background="{StaticResource AmberTintBrush}"
                        Command="{x:Bind ViewModel.NavigateToStaffCommand}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Employee"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Flight crew – view schedule and assigned flights."
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="172"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <HyperlinkButton Content="← Back to role selection"
                 HorizontalAlignment="Center"
                 Foreground="{StaticResource DarkMutedTextBrush}"
                 Margin="0,28,0,0"
                 Command="{x:Bind ViewModel.NavigateToAirportCommand}"/>
        </StackPanel>
    </Grid>
</Page>
