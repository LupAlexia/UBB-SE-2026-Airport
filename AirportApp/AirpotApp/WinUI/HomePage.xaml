<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0F172A">

    <Page.Resources>
        <Style x:Key="RoleCardStyle" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="MinHeight" Value="160"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,28"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="0">

            <TextBlock Text="Staff Portal"
                       FontSize="38"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Select your role to continue"
                       FontSize="15"
                       Foreground="#A0AEC0"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,36"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel.Resources>
                    <ResourceDictionary>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#111827"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#2bb8c0"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#F8FAFC"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#111827"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#2bb8c0"/>
                    </ResourceDictionary>
                </StackPanel.Resources>

                <!-- Admin -->
                <Button Style="{StaticResource RoleCardStyle}"
                        Command="{x:Bind ViewModel.NavigateToAdminCommand}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Admin"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Manage FAQ, tickets, reviews, employees, routes, and gates."
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="172"/>
                    </StackPanel>
                </Button>

                <!-- Manager (Company Representative) -->
                <Button Style="{StaticResource RoleCardStyle}"
                        Command="{x:Bind ViewModel.NavigateToCompanyCommand}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Manager"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Flight company manager – add and manage flights."
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="172"/>
                    </StackPanel>
                </Button>

                <!-- Employee (Airport Staff Member) -->
                <Button Style="{StaticResource RoleCardStyle}"
                        Command="{x:Bind ViewModel.NavigateToStaffCommand}">
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <TextBlock Text="Employee"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Flight crew – view schedule and assigned flights."
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   MaxWidth="172"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <HyperlinkButton Content="← Back to role selection"
                 HorizontalAlignment="Center"
                 Foreground="#A0AEC0"
                 Margin="0,28,0,0"
                 Command="{x:Bind ViewModel.NavigateToAirportCommand}"/>
        </StackPanel>
    </Grid>
</Page>