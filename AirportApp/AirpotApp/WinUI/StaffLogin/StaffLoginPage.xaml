<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.StaffLogin.StaffLoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource DarkPanelBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="22"
                    Width="340">

            <TextBlock Text="STAFF LOGIN"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"/>

            <TextBox PlaceholderText="Enter Employee ID"
                     HorizontalContentAlignment="Center"
                     Height="44"
                     FontSize="15"
                     Text="{x:Bind ViewModel.EmployeeIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Content="Login"
                    HorizontalAlignment="Stretch"
                    Height="48"
                    FontSize="16"
                    FontWeight="SemiBold"
                    CornerRadius="8"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    Command="{x:Bind ViewModel.LoginCommand}"/>

            <TextBlock Foreground="{StaticResource ErrorBrush}"
                       HorizontalAlignment="Center"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"/>
        </StackPanel>
    </Grid>
</Page>
