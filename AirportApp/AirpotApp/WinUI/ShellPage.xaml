<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:AirportApp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#0F172A">

    <Page.Resources>
        <converters:BoolToActiveBrushConverter x:Key="BoolToActiveBrushConverter" />
        <converters:BoolToInactiveBrushConverter x:Key="BoolToInactiveBrushConverter" />
        <converters:BoolToActiveBorderBrushConverter x:Key="BoolToActiveBorderBrushConverter" />
        <converters:BoolToActiveBorderThicknessConverter x:Key="BoolToActiveBorderThicknessConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1E293B"
                BorderBrush="#3F3F46"
                BorderThickness="0,0,0,1"
                Padding="30,15,30,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Airport Management System"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#2bb8c0"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="15"
                            VerticalAlignment="Center">

                    <Button Content="Airport Management"
                            Command="{x:Bind ViewModel.NavigateToAirportCommand}"
                            Background="{x:Bind ViewModel.IsAirportTabActive, Converter={StaticResource BoolToActiveBrushConverter}}"
                            BorderBrush="{x:Bind ViewModel.IsAirportTabActive, Converter={StaticResource BoolToActiveBorderBrushConverter}}"
                            BorderThickness="{x:Bind ViewModel.IsAirportTabActive, Converter={StaticResource BoolToActiveBorderThicknessConverter}}"
                            Foreground="White"
                            Padding="15,8"
                            CornerRadius="6"
                            FontWeight="SemiBold" />

                    <Button Content="Duty-Free Shops"
                            Command="{x:Bind ViewModel.NavigateToShopCommand}"
                            Background="{x:Bind ViewModel.IsAirportTabActive, Converter={StaticResource BoolToInactiveBrushConverter}}"
                            BorderBrush="{x:Bind ViewModel.IsAirportTabActive, Converter={StaticResource BoolToActiveBorderBrushConverter}, ConverterParameter=Invert}"
                            BorderThickness="{x:Bind ViewModel.IsAirportTabActive, Converter={StaticResource BoolToActiveBorderThicknessConverter}, ConverterParameter=Invert}"
                            Foreground="White"
                            Padding="15,8"
                            CornerRadius="6"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Background="#0F172A" />
    </Grid>
</Page>
