<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.NoAirportRolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F172A">

    <Grid Padding="48">
        <Border MaxWidth="560"
                Padding="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1E293B"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel Spacing="14">
                <TextBlock Text="Airport Management is not available"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="The configured user does not have an Airport Management role. Switch to Duty-Free Shops or choose a different UserID in appsettings.json."
                           Foreground="#CBD5E1"
                           FontSize="16"
                           LineHeight="24"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
