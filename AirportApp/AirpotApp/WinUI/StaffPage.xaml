<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.StaffPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="using:AirportApp.WinUI.Components"
    xmlns:data="using:AirportApp.ClassLibrary.Entity.Domain"
    mc:Ignorable="d"
    Background="{StaticResource DarkBackgroundBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <components:Header Grid.Row="0"/>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource DarkPanelBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{StaticResource DarkPanelBrush}"
                Width="980"
                Height="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,20,20,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="MY SCHEDULED FLIGHTS"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Refresh"
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            Padding="16,8"
                            CornerRadius="4"
                            Command="{x:Bind ViewModel.RefreshCommand}"/>
                </Grid>

                <Grid Grid.Row="1" Margin="20,0,20,15" ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource TealTintBrush}" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="EMPLOYEE ID" Foreground="{StaticResource DarkMutedTextBrush}" FontSize="12"/>
                            <TextBlock Text="{x:Bind ViewModel.EmployeeIdText, Mode=OneWay}" Foreground="{StaticResource PrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource IndigoTintBrush}" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="ROLE" Foreground="{StaticResource DarkMutedTextBrush}" FontSize="12"/>
                            <TextBlock Text="{x:Bind ViewModel.RoleText, Mode=OneWay}" Foreground="{StaticResource IndigoBrush}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource AmberTintBrush}" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="ASSIGNED FLIGHTS" Foreground="{StaticResource DarkMutedTextBrush}" FontSize="12"/>
                            <TextBlock Text="{x:Bind ViewModel.FlightsCountText, Mode=OneWay}" Foreground="{StaticResource WarningBrush}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Background="{StaticResource TealTintBrush}" Padding="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.6*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="ID" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="FLIGHT NO." Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="TYPE" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="DATE" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="GATE" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="RUNWAY" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="TIME" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="3">
                    <ListView SelectionMode="None"
                              BorderThickness="0"
                              ItemsSource="{x:Bind ViewModel.ScheduledFlights, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="data:EmployeeScheduleItem">
                                <Grid Padding="15,12" BorderThickness="0,0,0,1" BorderBrush="{StaticResource DarkBorderBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.6*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Foreground="{StaticResource DarkMutedTextBrush}" HorizontalAlignment="Center" Text="{Binding Id}"/>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource DarkForegroundBrush}" FontWeight="Bold" HorizontalAlignment="Center" Text="{Binding FlightNumber}"/>
                                    <TextBlock Grid.Column="2" Foreground="{StaticResource DarkForegroundBrush}" HorizontalAlignment="Center" Text="{Binding FlightType}"/>
                                    <TextBlock Grid.Column="3" Foreground="{StaticResource DarkForegroundBrush}" HorizontalAlignment="Center" Text="{Binding Date}"/>
                                    <TextBlock Grid.Column="4" Foreground="{StaticResource DarkForegroundBrush}" HorizontalAlignment="Center" Text="{Binding GateName}"/>
                                    <TextBlock Grid.Column="5" Foreground="{StaticResource DarkForegroundBrush}" HorizontalAlignment="Center" Text="{Binding RunwayName}"/>
                                    <TextBlock Grid.Column="6" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" Text="{Binding FlightTime}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock Text="This employee has no scheduled flights."
                               Foreground="{StaticResource DarkMutedTextBrush}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
