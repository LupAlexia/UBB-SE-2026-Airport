<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.DutyFreeShops.ShopPage.DutyFreeShopPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:domain="using:AirportApp.ClassLibrary.Entity.Domain"
    xmlns:converters="using:AirportApp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource PageBackgroundBrush}" Padding="100 0 0 0" RequestedTheme="Light">
        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Padding="20 30 30 30" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="DutyFree Shops"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}"/>

            <AutoSuggestBox Grid.Column="1"
                            Height="40"
                            PlaceholderText="Search shops or categories..."
                            QuerySubmitted="SearchBox_QuerySubmitted"
                            CornerRadius="8"
                            Width="500"
                            Margin="0 5 0 0"
                            BorderBrush="{StaticResource BorderBrush}"/>

            <Button Grid.Column="3"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    CornerRadius="4"
                    Padding="15,8"
                    x:Name="CartButton">
                <SymbolIcon Symbol="Shop"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Margin="20 0 0 0"
                    x:Name="AddShopButton"
                    Height="35" Width="110"
                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                    Padding="5"
                    Content="+ Add Shop"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Sort by:" VerticalAlignment="Center" Opacity="0.7"/>
                <ComboBox x:Name="SortComboBox" Width="220"
                          SelectionChanged="SortComboBox_SelectionChanged"
                          Padding="5,2">
                    <ComboBoxItem Content="None"/>
                    <ComboBoxItem Content="Shop Name"/>
                    <ComboBoxItem Content="Reviews"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2">
            <GridView x:Name="ShopsGridView"
                      ItemsSource="{x:Bind ViewModel.Shops, Mode=OneWay}"
                      IsItemClickEnabled="True"
                      Padding="20"
                      Tag="{x:Bind ViewModel.IsAdmin, Mode=OneWay}">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="domain:Shop">
                        <Border MinWidth="300" Height="120" Margin="10"
                                CornerRadius="12" Background="{StaticResource CardBackgroundBrush}" Padding="15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}" Grid.Column="0"
                                               VerticalAlignment="Center"/>

                                    <Button Width="40" Height="30" Grid.Column="1"
                                            Click="EditShopButton_Click"
                                            DataContext="{Binding}"
                                            Margin="0 0 10 0"
                                            Tag="{Binding}"
                                            Visibility="{Binding Tag, ElementName=ShopsGridView, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="?" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>

                                    <Button Width="40" Height="30" Grid.Column="2"
                                            Click="DeleteShopButton_Click"
                                            DataContext="{Binding}"
                                            Tag="{Binding}"
                                            Visibility="{Binding Tag, ElementName=ShopsGridView, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="-" FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="{x:Bind Type}"
                                           Margin="0,5,0,0"
                                           Opacity="0.6"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>
    </Grid>
</Page>
