<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.DutyFreeShops.CartPage.DutyFreeCartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource PageBackgroundBrush}" Padding="20" RequestedTheme="Light">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Grid Padding="10,15,20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderBrush="Transparent" Padding="10" Click="BackButton_Click">
                        <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                    </Button>
                    <TextBlock Text="Duty-free shops" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                </StackPanel>
            </Grid>
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"/>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.CartShopItems, Mode=OneWay}"
                  SelectionMode="None"
                  MaxWidth="1300">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,15,0,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Source="/Assets/PlaceHolder.png" Width="80" Height="80" Margin="0,0,20,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ShopItem.Name}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DisplayPrice}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,40,0">
                            <Button Content="-" Width="40" Height="40" Margin="0,0,10,0" Click="DecreaseQuantity_Click"/>
                            <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" FontSize="18" Margin="0,0,10,0"/>
                            <Button Content="+" Width="40" Height="40" Click="IncreaseQuantity_Click"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text="{Binding ItemTotalPrice}" VerticalAlignment="Center"
                                   FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Margin="0,30,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Empty Cart" HorizontalAlignment="Left"
                    Background="Transparent" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"
                    Foreground="{StaticResource PrimaryBrush}" Click="EmptyCart_Click"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <StackPanel Orientation="Vertical" Margin="0,0,25,0" HorizontalAlignment="Right">
                    <TextBlock Text="Overall Total Price" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right"/>
                    <TextBlock Text="{x:Bind ViewModel.OverallTotal, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                </StackPanel>

                <Button Content="Reserve" Width="140" Height="50"
                        Background="{StaticResource PrimaryBrush}" Foreground="White" FontSize="16" FontWeight="SemiBold"
                        IsEnabled="{x:Bind ViewModel.IsReserveButtonEnabled, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ReserveCartCommand}"/>

                <Button Content="Cancel Reservation" Width="170" Height="50"
                        Background="{StaticResource ErrorBrush}" Foreground="White" FontSize="16" FontWeight="SemiBold"
                        Visibility="{x:Bind BoolToVisibility(ViewModel.IsCancelButtonVisible), Mode=OneWay}"
                        Margin="15,0,0,0"
                        Command="{x:Bind ViewModel.CancelReservationCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
