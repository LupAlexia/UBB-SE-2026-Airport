<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.DutyFreeShops.ItemDetailsPage.DutyFreeItemDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" Background="{StaticResource PageBackgroundBrush}">
        <Grid.Resources>
            <Style x:Key="VisibleTextBoxStyle" TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HeaderTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" Padding="16,12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="BackButton_Click"
                    Background="Transparent" BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="18" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Back" Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1" Text="Duty-free shops" Margin="14,0"
                       VerticalAlignment="Center" FontSize="28" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}"/>

            <Button x:Name="ViewCartButton" Grid.Column="3" Click="ViewCart_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon x:Name="ViewCartIcon" Glyph="&#xE7BF;" FontSize="18"/>
                    <TextBlock x:Name="ViewCartText" Text="View Cart" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="40,24">
            <Grid ColumnSpacing="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="16" Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Height="300">
                    <Image Source="/Assets/PlaceHolder.png" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" Spacing="12">
                    <TextBlock x:Name="TitleText" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>

                    <TextBlock x:Name="DescText" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="PriceText" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="In stock:" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StockUnitsRun" Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="ClientActionsPanel" Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="-"
                                    Width="40"
                                    Height="40"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Background="{StaticResource BorderBrush}"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    CornerRadius="6"
                                    Click="QuantityMinus_Click"/>

                            <TextBox x:Name="QuantityBox"
                                     Width="60"
                                     Height="40"
                                     TextAlignment="Center"
                                     VerticalAlignment="Center"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     TextChanged="QuantityBox_TextChanged"/>

                            <Button Content="+"
                                    Width="40"
                                    Height="40"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Background="{StaticResource BorderBrush}"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    CornerRadius="6"
                                    Click="QuantityPlus_Click"/>
                        </StackPanel>

                        <Button Content="Add to Cart" Background="{StaticResource PrimaryBrush}"
                                Foreground="White" CornerRadius="8" Padding="16,10"
                                Click="AddToCart_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="AdminActionsPanel" Spacing="12" Visibility="Collapsed">
                        <TextBox x:Name="AdminNameBox" Header="Name" PlaceholderText="Item name" Style="{StaticResource VisibleTextBoxStyle}"/>
                        <TextBox x:Name="AdminDescBox" Header="Description" PlaceholderText="Description" Style="{StaticResource VisibleTextBoxStyle}"/>
                        <TextBox x:Name="AdminPriceBox" Header="Price" PlaceholderText="0.00" Style="{StaticResource VisibleTextBoxStyle}"/>
                        <TextBox x:Name="AdminStockBox" Header="Stock" PlaceholderText="0" Style="{StaticResource VisibleTextBoxStyle}"/>
                        <TextBlock x:Name="AdminStatusText" Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold"/>
                        <Button Content="Save Changes" Background="{StaticResource PrimaryBrush}"
                                Foreground="White" CornerRadius="8" Padding="16,10"
                                Click="AdminSave_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
