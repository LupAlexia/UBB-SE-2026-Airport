<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.DutyFreeShops.ShopItemsPage.DutyFreeShopItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:domain="using:AirportApp.ClassLibrary.Entity.Domain"
    xmlns:converters="using:AirportApp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource CardBackgroundBrush}" Padding="0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Top" Margin="5" Spacing="5">

                    <Button Click="BackToShops_Click" Background="Transparent" BorderThickness="0">
                        <Grid>
                            <SymbolIcon Width="10" Height="10" Foreground="{StaticResource PrimaryBrush}"
                                        HorizontalAlignment="Left" Symbol="Back"/>
                            <TextBlock Margin="20,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource PrimaryBrush}" Text="Back to Shops"/>
                        </Grid>
                    </Button>

                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="5,0" Height="30"/>

                    <TextBlock x:Name="ShopNameTextBlock" VerticalAlignment="Center"
                               FontSize="24" Foreground="{StaticResource PrimaryBrush}" Text=""/>

                    <Grid Padding="50,0,0,0" Width="500" Height="50">
                        <TextBox FontSize="18" x:Name="SearchBox"
                                 PlaceholderText="Search"
                                 KeyDown="SearchBox_KeyDown"
                                 Padding="35,13,0,0"
                                 VerticalAlignment="Stretch"
                                 HorizontalAlignment="Stretch"/>
                        <SymbolIcon Symbol="Find" VerticalAlignment="Center"
                                    HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </Grid>

                    <Button x:Name="CartButton"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        Padding="12,6,12,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7BF;" VerticalAlignment="Center"/>
                            <TextBlock Text="Cart" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Height="2" Background="{StaticResource BorderBrush}" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="150,25,150,25" Background="{StaticResource CardBackgroundBrush}">
            <StackPanel Spacing="20">
                <Button x:Name="AddButton"
                        Click="AddButton_Click"
                        FontSize="16" Foreground="White"
                        Content="+ Add Item"
                        CornerRadius="15" Background="{StaticResource PrimaryBrush}"
                        Width="130" Height="50"
                        Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Sort by:" VerticalAlignment="Center" Opacity="0.7"/>
                    <ComboBox x:Name="SortComboBox" Width="220"
                              SelectionChanged="SortComboBox_SelectionChanged" Padding="5,2">
                        <ComboBoxItem Content="None"/>
                        <ComboBoxItem Content="Name"/>
                        <ComboBoxItem Content="Price"/>
                    </ComboBox>
                </StackPanel>

                <GridView x:Name="ItemsGridView"
                          IsItemClickEnabled="True"
                          Background="{StaticResource CardBackgroundBrush}"
                          ItemClick="GridView_ItemClick"
                          Tag="{x:Bind ViewModel.IsAdmin, Mode=OneWay}">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="domain:ShopItem">
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="5">
                                <StackPanel Width="250" Height="300">
                                    <Grid Height="180" Width="200">
                                        <Image Source="{Binding Photo, Converter={StaticResource PathToImageConverter}}"
                                               Stretch="UniformToFill"/>

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="5" Spacing="5"
                                                    Visibility="{Binding Tag, ElementName=ItemsGridView, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Button Click="EditButton_Click" Tag="{x:Bind}">
                                                <SymbolIcon Symbol="Edit"/>
                                            </Button>
                                            <Button Click="DeleteButton_Click" Tag="{x:Bind}">
                                                <SymbolIcon Foreground="{StaticResource ErrorBrush}" Symbol="Delete"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold" Margin="0,20,0,0" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="{x:Bind Description}" Margin="0,10,0,5" Foreground="{StaticResource PrimaryTextBrush}"/>

                                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" Text="{Binding Quantity}"
                                                   Visibility="{Binding Tag, ElementName=ItemsGridView, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <Grid Grid.Column="2" ColumnSpacing="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="$" FontWeight="Bold" FontSize="24" Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Price}" FontWeight="Bold" FontSize="24" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Grid>

                                        <Button Grid.Column="1"
                                                Content="Add to Cart"
                                                Background="{StaticResource PrimaryBrush}"
                                                Click="AddItemToCartButton_Click"
                                                Tag="{x:Bind}"
                                                Foreground="White"
                                                Visibility="{Binding Tag, ElementName=ItemsGridView, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
