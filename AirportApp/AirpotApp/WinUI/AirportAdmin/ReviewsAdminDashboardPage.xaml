<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.AirportAdmin.ReviewsAdminDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    Foreground="{StaticResource DarkForegroundBrush}">

    <Page.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Customer Reviews"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="View customer feedback and ratings (read-only)"
                           Foreground="{StaticResource DarkMutedTextBrush}"
                           FontSize="14"/>
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}">
                <StackPanel Spacing="24">
                    <TextBlock Text="Overall Statistics"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>

                    <Grid ColumnDefinitions="*, *, *, *, *">
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Total Reviews"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding TotalReviews}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Duty Free Shops"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <RatingControl Value="{Binding AverageDutyFree}"
                                             IsReadOnly="True"
                                             Foreground="{StaticResource SkyBrush}"/>
                            <TextBlock Text="{Binding AverageDutyFree}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SkyBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Flight Experience"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <RatingControl Value="{Binding AverageFlightExperience}"
                                             IsReadOnly="True"
                                             Foreground="{StaticResource IndigoBrush}"/>
                            <TextBlock Text="{Binding AverageFlightExperience}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource IndigoBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Staff Friendliness"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <RatingControl Value="{Binding AverageStaffFriendliness}"
                                             IsReadOnly="True"
                                             Foreground="{StaticResource PinkBrush}"/>
                            <TextBlock Text="{Binding AverageStaffFriendliness}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PinkBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Cleanliness"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <RatingControl Value="{Binding AverageCleanliness}"
                                             IsReadOnly="True"
                                             Foreground="{StaticResource VioletBrush}"/>
                            <TextBlock Text="{Binding AverageCleanliness}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource VioletBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <ItemsControl Grid.Row="4" ItemsSource="{Binding Reviews}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <Grid RowDefinitions="Auto, Auto, Auto">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Border Width="48"
                                            Height="48"
                                            BorderBrush="{StaticResource DarkBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="24">
                                        <TextBlock Text="{Binding userId}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontWeight="Bold"/>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="16,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding userName}"
                                                   FontWeight="Bold"
                                                   FontSize="18"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="Overall Rating"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DarkMutedTextBrush}"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,0,2"/>
                                        <RatingControl Value="{Binding overallRating}"
                                                       IsReadOnly="True"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="*, *, *, *"
                                      Margin="0,24">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Duty Free Shops"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DarkMutedTextBrush}"/>
                                        <RatingControl Value="{Binding dutyFreeRating}"
                                                       IsReadOnly="True"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Flight Experience"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DarkMutedTextBrush}"/>
                                        <RatingControl Value="{Binding flightExperienceRating}"
                                                       IsReadOnly="True"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Text="Staff Friendliness"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DarkMutedTextBrush}"/>
                                        <RatingControl Value="{Binding staffFriendlinessRating}"
                                                       IsReadOnly="True"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Spacing="4">
                                        <TextBlock Text="Cleanliness"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DarkMutedTextBrush}"/>
                                        <RatingControl Value="{Binding cleanlinessRating}"
                                                       IsReadOnly="True"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="2"
                                        BorderBrush="{StaticResource DarkBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16">
                                    <TextBlock Text="{Binding message}"
                                               FontStyle="Italic"
                                               Foreground="{StaticResource DarkSubtleTextBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</Page>
