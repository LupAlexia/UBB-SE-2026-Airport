<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.AirportAdmin.FAQAdminDashboardPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirportApp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:AirportApp.ClassLibrary.Entity.Dto"
    mc:Ignorable="d"
    Background="Transparent"
    Foreground="{StaticResource DarkForegroundBrush}">

    <Page.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:BooleanToGlyphConverter x:Key="BooleanToGlyphConverter"/>

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SelectedCategoryButtonStyle" TargetType="Button" BasedOn="{StaticResource CategoryButtonStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        </Style>

        <Style x:Key="PopularQuestionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource DarkForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>

        <Style x:Key="FaqAccordionHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="FAQ Management"
                       FontSize="24"
                       FontWeight="SemiBold"/>

            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Popular Questions"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <ItemsControl ItemsSource="{Binding FilteredFAQs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="dto:FAQEntryDTO">
                                <Button Style="{StaticResource PopularQuestionButtonStyle}"
                                        Click="OpenFaqButton_Click"
                                        Width="280">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Question}"
                                                   TextWrapping="WrapWholeWords"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                        <Border Grid.Column="1"
                                                BorderBrush="{StaticResource DarkBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="8,4"
                                                VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE8A7;" FontSize="11" Foreground="{StaticResource DarkMutedTextBrush}"/>
                                                <TextBlock Text="{Binding ViewCount}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource DarkMutedTextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource SectionBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBox PlaceholderText="Search FAQs by question / answer..."
                             Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AllQuestionsButton"
                                    Content="All Questions"
                                    Style="{StaticResource SelectedCategoryButtonStyle}"
                                    Click="AllQuestionsButton_Click"/>
                            <Button x:Name="CheckInButton"
                                    Content="Check-in Procedures"
                                    Style="{StaticResource CategoryButtonStyle}"
                                    Click="CheckInButton_Click"/>
                            <Button x:Name="ParkingButton"
                                    Content="Parking"
                                    Style="{StaticResource CategoryButtonStyle}"
                                    Click="ParkingButton_Click"/>
                            <Button x:Name="BaggageButton"
                                    Content="Baggage"
                                    Style="{StaticResource CategoryButtonStyle}"
                                    Click="BaggageButton_Click"/>
                            <Button x:Name="FaqCategoryTicketsButton"
                                    Content="Tickets"
                                    Style="{StaticResource CategoryButtonStyle}"
                                    Click="TicketButton_Click"/>
                            <Button x:Name="FacilitiesButton"
                                    Content="Facilities"
                                    Style="{StaticResource CategoryButtonStyle}"
                                    Click="FacilitiesButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">
                        <Button x:Name="AddFaqButton"
                                Content="Add"
                                Click="AddFaqButton_Click"
                                Style="{StaticResource SelectedCategoryButtonStyle}"/>
                        <Button x:Name="EditFaqButton"
                                Content="Edit"
                                Click="EditFaqButton_Click"
                                Style="{StaticResource CategoryButtonStyle}"/>
                        <Button x:Name="DeleteFaqButton"
                                Content="Delete"
                                Click="DeleteFaqButton_Click"
                                Style="{StaticResource CategoryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource SectionBorderStyle}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="Manage airport FAQ entries"
                                   FontSize="12"
                                   Foreground="{StaticResource DarkMutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <ItemsControl x:Name="AllQuestionsList" ItemsSource="{Binding FilteredFAQs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="dto:FAQEntryDTO">
                                <Border Margin="0,0,0,12"
                                        BorderBrush="{StaticResource DarkBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14">
                                    <StackPanel Spacing="10">
                                        <Button Click="AccordionHeader_Click"
                                                Style="{StaticResource FaqAccordionHeaderButtonStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{Binding Question}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding Category}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE8A7;"
                                                                      FontSize="11"
                                                                      Foreground="{StaticResource DarkMutedTextBrush}"/>
                                                            <TextBlock Text="{Binding ViewCount}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource DarkMutedTextBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                                <FontIcon Grid.Column="1"
                                                          Glyph="{Binding IsExpanded, Converter={StaticResource BooleanToGlyphConverter}}"
                                                          Foreground="{StaticResource DarkMutedTextBrush}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Spacing="12">
                                            <TextBlock Text="{Binding Answer}"
                                                       TextWrapping="Wrap"
                                                       FontSize="13"
                                                       Foreground="{StaticResource DarkSubtleTextBrush}"
                                                       LineHeight="22"/>
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Feedback summary"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="16">
                                                    <TextBlock Text="{Binding HelpfulVotesCount, ConverterParameter='Helpful: \{0\}'}"
                                                               Foreground="{StaticResource SuccessBrush}"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding NotHelpfulVotesCount, ConverterParameter='Not helpful: \{0\}'}"
                                                               Foreground="{StaticResource ErrorBrush}"
                                                               FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
