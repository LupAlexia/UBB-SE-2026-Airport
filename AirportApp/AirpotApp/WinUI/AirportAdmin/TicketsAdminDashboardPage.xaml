<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.AirportAdmin.TicketsAdminDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dto="using:AirportApp.ClassLibrary.Entity.Dto"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    Foreground="{StaticResource DarkForegroundBrush}">

    <Page.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="AdminButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style x:Key="StatusLegendStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Height" Value="70"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Support Tickets"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Resolve customer requests"
                           FontSize="14"
                           Foreground="{StaticResource DarkMutedTextBrush}"/>
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Filter"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Change the status of submitted tickets."
                                   FontSize="14"
                                   Foreground="{StaticResource DarkMutedTextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <SymbolIcon Symbol="Filter"
                                    Foreground="{StaticResource DarkMutedTextBrush}"
                                    Width="20"
                                    Height="20"/>
                        <ComboBox Width="180"
                                  PlaceholderText="Filter tickets"
                                  SelectedIndex="0"
                                  SelectionChanged="FilterChanged">
                            <ComboBoxItem Content="All Tickets" Tag="ALL"/>
                            <ComboBoxItem Content="Open" Tag="OPEN"/>
                            <ComboBoxItem Content="In Progress" Tag="IN_PROGRESS"/>
                            <ComboBoxItem Content="Resolved" Tag="RESOLVED"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource SectionBorderStyle}">
                <ItemsControl x:Name="TicketList"
                              ItemsSource="{x:Bind ViewModel.FilteredTicketsForDisplay, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dto:TicketDTO">
                            <Border BorderBrush="{StaticResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{x:Bind ticketId}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DarkMutedTextBrush}"/>
                                        <TextBlock Text="{x:Bind subject}"
                                                   FontSize="18"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{x:Bind description}"
                                                   Foreground="{StaticResource DarkSubtleTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,8"/>

                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{x:Bind categoryName}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource DarkMutedTextBrush}"/>
                                            <TextBlock Text="|" Foreground="{StaticResource DarkMutedTextBrush}"/>
                                            <TextBlock Text="{x:Bind subcategoryName}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource DarkMutedTextBrush}"/>
                                            <TextBlock Text="|" Foreground="{StaticResource DarkMutedTextBrush}"/>
                                            <TextBlock Text="{x:Bind creationTimestamp}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource DarkMutedTextBrush}"/>
                                            <TextBlock Text="|" Foreground="{StaticResource DarkMutedTextBrush}"/>
                                            <TextBlock Text="{x:Bind creatorEmailAddress}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource DarkMutedTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Top"
                                                Spacing="8">
                                        <Border BorderBrush="{StaticResource DarkBorderBrush}"
                                                BorderThickness="1"
                                                Padding="8,4"
                                                CornerRadius="4">
                                            <TextBlock Text="{x:Bind currentStatus}"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <Border BorderBrush="{StaticResource DarkBorderBrush}"
                                                BorderThickness="1"
                                                Padding="8,4"
                                                CornerRadius="4">
                                            <TextBlock Text="{x:Bind urgencyLevel}"
                                                       Foreground="{StaticResource ErrorBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <Button Content="Update Status"
                                                Click="EditTicketStatus_Click"
                                                Tag="{x:Bind ticketId}"
                                                Style="{StaticResource AdminButtonStyle}"
                                                Margin="10,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Grid Grid.Row="6" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatusLegendStyle}" Background="{StaticResource AmberTintBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Clock"
                                    Foreground="{StaticResource WarningBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Open" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Awaiting review"
                                       FontSize="11"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatusLegendStyle}" Background="{StaticResource SkyTintBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Sync"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="In Progress" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Under investigation"
                                       FontSize="11"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatusLegendStyle}" Background="{StaticResource GreenTintBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Accept"
                                    Foreground="{StaticResource SuccessBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Resolved" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Issue closed"
                                       FontSize="11"
                                       Foreground="{StaticResource DarkMutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
