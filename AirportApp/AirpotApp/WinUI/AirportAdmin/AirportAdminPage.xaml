<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.WinUI.AirportAdmin.AirportAdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="using:AirportApp.WinUI.Components"
    mc:Ignorable="d"
    Background="{StaticResource DarkBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="SidebarNavItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </Page.Resources>

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <components:Header Grid.Row="0" Grid.ColumnSpan="2"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource DarkPanelBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="ADMIN PANEL"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="10,10,10,20"/>

                    <Button x:Name="FlightsButton"
                            Style="{StaticResource SidebarNavItemStyle}"
                            Command="{x:Bind ViewModel.ShowFlightsCommand}">
                        <Grid Height="44" Padding="14,0">
                            <TextBlock Text="FLIGHTS" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="EmployeesButton"
                            Style="{StaticResource SidebarNavItemStyle}"
                            Command="{x:Bind ViewModel.ShowEmployeesCommand}">
                        <Grid Height="44" Padding="14,0">
                            <TextBlock Text="EMPLOYEES" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="AirportButton"
                            Style="{StaticResource SidebarNavItemStyle}"
                            Command="{x:Bind ViewModel.ShowAirportCommand}">
                        <Grid Height="44" Padding="14,0">
                            <TextBlock Text="AIRPORT" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="FAQButton"
                            Style="{StaticResource SidebarNavItemStyle}"
                            Command="{x:Bind ViewModel.ShowFAQCommand}">
                        <Grid Height="44" Padding="14,0">
                            <TextBlock Text="FAQ" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="TicketsButton"
                            Style="{StaticResource SidebarNavItemStyle}"
                            Command="{x:Bind ViewModel.ShowTicketsCommand}">
                        <Grid Height="44" Padding="14,0">
                            <TextBlock Text="TICKETS" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="ReviewsButton"
                            Style="{StaticResource SidebarNavItemStyle}"
                            Command="{x:Bind ViewModel.ShowReviewsCommand}">
                        <Grid Height="44" Padding="14,0">
                            <TextBlock Text="REVIEWS" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource DarkPanelBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="AIRPORT ADMINISTRATION"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>

                    <Frame x:Name="ContentFrame" Grid.Row="2" Background="Transparent"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
