<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AirportApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:AirportApp.Converters"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="PrimaryColor">#2BB8C0</Color>
            <Color x:Key="PrimaryLightColor">#3DD1DA</Color>
            <Color x:Key="PrimaryMutedColor">#A8E6E9</Color>
            <Color x:Key="PrimaryTextColor">#111827</Color>
            <Color x:Key="SecondaryTextColor">#6B7280</Color>
            <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="PageBackgroundColor">#F0F4F8</Color>
            <Color x:Key="InputBackgroundColor">#F9FEFF</Color>
            <Color x:Key="BorderColor">#E5E7EB</Color>
            <Color x:Key="ErrorColor">#EF4444</Color>
            <Color x:Key="SuccessColor">#10B981</Color>
            <Color x:Key="WarningColor">#F59E0B</Color>

            <!--  Extended accent palette for colourful components (cards, badges, stat
                  tiles, table headers). Each hue has a vivid solid + a soft tint that
                  is light enough for dark text to stay readable on top.  -->
            <Color x:Key="IndigoColor">#6366F1</Color>
            <Color x:Key="PinkColor">#EC4899</Color>
            <Color x:Key="SkyColor">#0EA5E9</Color>
            <Color x:Key="VioletColor">#8B5CF6</Color>
            <Color x:Key="TealTintColor">#D6F1F3</Color>
            <Color x:Key="IndigoTintColor">#E7E8FD</Color>
            <Color x:Key="PinkTintColor">#FBE3EF</Color>
            <Color x:Key="SkyTintColor">#DEF1FD</Color>
            <Color x:Key="VioletTintColor">#EFE8FE</Color>
            <Color x:Key="AmberTintColor">#FEF1C7</Color>
            <Color x:Key="GreenTintColor">#CFF6E4</Color>

            <!--  Unified light theme: the "Dark*" keys are legacy aliases kept so the
                  ~20 admin/staff pages that reference them flip to the light palette
                  without touching every reference. They now resolve to light surfaces
                  and dark text so the whole app shares one look.  -->
            <Color x:Key="DarkBackgroundColor">#F0F4F8</Color>
            <Color x:Key="DarkPanelColor">#FFFFFF</Color>
            <Color x:Key="DarkBorderColor">#E5E7EB</Color>
            <Color x:Key="DarkMutedTextColor">#6B7280</Color>
            <Color x:Key="DarkSubtleTextColor">#374151</Color>
            <Color x:Key="DarkForegroundColor">#111827</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
            <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
            <SolidColorBrush x:Key="PrimaryMutedBrush" Color="{StaticResource PrimaryMutedColor}" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
            <!--  Soft diagonal gradient used as the app-wide page background.  -->
            <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#DDF1F4" Offset="0" />
                <GradientStop Color="#E7E6FB" Offset="0.55" />
                <GradientStop Color="#FBE4ED" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />

            <LinearGradientBrush x:Key="DarkBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#DDF1F4" Offset="0" />
                <GradientStop Color="#E7E6FB" Offset="0.55" />
                <GradientStop Color="#FBE4ED" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="DarkPanelBrush" Color="{StaticResource DarkPanelColor}" />
            <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorderColor}" />
            <SolidColorBrush x:Key="DarkMutedTextBrush" Color="{StaticResource DarkMutedTextColor}" />
            <SolidColorBrush x:Key="DarkSubtleTextBrush" Color="{StaticResource DarkSubtleTextColor}" />
            <SolidColorBrush x:Key="DarkForegroundBrush" Color="{StaticResource DarkForegroundColor}" />

            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C7C7C7" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource PrimaryColor}" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E5E5E5" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource PrimaryColor}" />

            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

            <SolidColorBrush x:Key="IndigoBrush" Color="{StaticResource IndigoColor}" />
            <SolidColorBrush x:Key="PinkBrush" Color="{StaticResource PinkColor}" />
            <SolidColorBrush x:Key="SkyBrush" Color="{StaticResource SkyColor}" />
            <SolidColorBrush x:Key="VioletBrush" Color="{StaticResource VioletColor}" />
            <SolidColorBrush x:Key="TealTintBrush" Color="{StaticResource TealTintColor}" />
            <SolidColorBrush x:Key="IndigoTintBrush" Color="{StaticResource IndigoTintColor}" />
            <SolidColorBrush x:Key="PinkTintBrush" Color="{StaticResource PinkTintColor}" />
            <SolidColorBrush x:Key="SkyTintBrush" Color="{StaticResource SkyTintColor}" />
            <SolidColorBrush x:Key="VioletTintBrush" Color="{StaticResource VioletTintColor}" />
            <SolidColorBrush x:Key="AmberTintBrush" Color="{StaticResource AmberTintColor}" />
            <SolidColorBrush x:Key="GreenTintBrush" Color="{StaticResource GreenTintColor}" />

            <!--  Retint the built-in Windows accent (default blue) to our teal so every
                  framework control - AccentButtonStyle, toggles, check boxes, radio
                  buttons, sliders, focus rings, ComboBox/ListView selection - matches
                  the rest of the app instead of leaking a second blue.  -->
            <Color x:Key="SystemAccentColor">#2BB8C0</Color>
            <Color x:Key="SystemAccentColorLight1">#3DD1DA</Color>
            <Color x:Key="SystemAccentColorLight2">#5DD8DF</Color>
            <Color x:Key="SystemAccentColorLight3">#A8E6E9</Color>
            <Color x:Key="SystemAccentColorDark1">#239AA1</Color>
            <Color x:Key="SystemAccentColorDark2">#1B7C82</Color>
            <Color x:Key="SystemAccentColorDark3">#135E62</Color>

            <SolidColorBrush x:Key="AccentButtonBackground" Color="{StaticResource PrimaryColor}" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#239AA1" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#1B7C82" />
            <SolidColorBrush x:Key="AccentButtonForeground" Color="White" />
            <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="White" />
            <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="White" />

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            </Style>

            <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="Normal" />
            </Style>

            <Style x:Key="TitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40" />
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="DashboardButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="260" />
                <Setter Property="Height" Value="140" />
                <Setter Property="Margin" Value="15" />
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="White" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <converters:PathToImageConverter x:Key="PathToImageConverter" />

            <converters:BoolToActiveBrushConverter x:Key="BoolToActiveBrushConverter" />
            <converters:BoolToInactiveBrushConverter x:Key="BoolToInactiveBrushConverter" />
            <converters:BoolToActiveBorderBrushConverter x:Key="BoolToActiveBorderBrushConverter" />
            <converters:BoolToActiveBorderThicknessConverter x:Key="BoolToActiveBorderThicknessConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
