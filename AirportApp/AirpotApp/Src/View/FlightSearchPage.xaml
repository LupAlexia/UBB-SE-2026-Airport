<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.Src.View.FlightSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirportApp.Src.View"
    xmlns:general="using:AirportApp.Src.View.General"
    xmlns:domain="using:AirportApp.Src.ViewModel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Light">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <general:TravelTicketsNavControl Grid.Row="0" SelectedSection="Search"/>

        <Grid Grid.Row="1" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="20" Margin="0,0,0,30">
            <TextBlock Text="Find your next flight" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom">

                <StackPanel Spacing="4">
                    <TextBlock Text="Location" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                    <TextBox x:Name="locationInput"
                             PlaceholderText="e.g. Barcelona..."
                             Width="180"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Text="{x:Bind ViewModel.Location, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Flight Type" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Height="32">
                        <RadioButton x:Name="flightTypeDeparture" Content="Departure" Foreground="{StaticResource PrimaryTextBrush}"
                                     IsChecked="{x:Bind ViewModel.IsDeparture, Mode=TwoWay}" />
                        <RadioButton x:Name="flightTypeArrival" Content="Arrival" Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Date" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <CalendarDatePicker x:Name="datePicker"
                                            PlaceholderText="Select date"
                                            Width="150"
                                            Date="{x:Bind ViewModel.FlightDate, Mode=TwoWay}"
                                            CalendarViewDayItemChanging="DatePicker_CalendarViewDayItemChanging"
                                            BorderBrush="{StaticResource BorderBrush}">
                            <CalendarDatePicker.Resources>
                                <SolidColorBrush x:Key="CalendarDatePickerBorderBrush" Color="{StaticResource BorderColor}"/>
                                <SolidColorBrush x:Key="CalendarDatePickerForeground" Color="{StaticResource PrimaryTextColor}"/>
                                <SolidColorBrush x:Key="CalendarDatePickerTextForeground" Color="{StaticResource PrimaryTextColor}"/>
                                <SolidColorBrush x:Key="CalendarDatePickerBackground" Color="{StaticResource CardBackgroundColor}"/>
                            </CalendarDatePicker.Resources>
                        </CalendarDatePicker>
                        <Button Content="✕" Background="Transparent" Foreground="{StaticResource SecondaryTextBrush}"
                                BorderThickness="0" VerticalAlignment="Center"
                                Height="32" ToolTipService.ToolTip="Clear Date"
                                Click="ClearDateButton_Click">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource BorderColor}"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource PrimaryTextColor}"/>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Passengers" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                    <TextBox x:Name="passengersInput"
                             PlaceholderText="Nr"
                             Width="80"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Text="{x:Bind ViewModel.Passengers, Mode=TwoWay}"
                             InputScope="Number"
                             BeforeTextChanging="PassengersInput_BeforeTextChanging"/>
                </StackPanel>

                <Button x:Name="searchButton" Content="SEARCH"
                        Command="{x:Bind ViewModel.SearchCommand}"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        FontWeight="Bold"
                        Height="32"
                        VerticalAlignment="Bottom">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource PrimaryLightColor}"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource PrimaryMutedColor}"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Available Flights" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.SearchResultMessage, Mode=OneWay}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,10"/>

            <ListView x:Name="flightsGrid" ItemsSource="{x:Bind ViewModel.AvailableFlights, Mode=OneWay}"
                      Grid.Row="2" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" CornerRadius="8" SelectionMode="Single">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Background="{StaticResource CardBackgroundBrush}" Padding="12" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Flight Nr" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="Route" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="2" Text="Date &amp; Time" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="3" Text="Base Price / person" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="4" Text="Action" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="domain:FlightDisplayModel">
                        <Grid Background="{StaticResource CardBackgroundBrush}" Padding="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind FlightNumber}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind RouteCity}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind DisplayDate}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind DisplayPrice}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>

                            <Button Grid.Column="4" Content="Book" Background="{StaticResource PrimaryBrush}" Foreground="White" CornerRadius="4" Height="30" HorizontalAlignment="Right" Margin="8,0,0,0"
                                    Command="{Binding DataContext.BookFlightCommand, ElementName=flightsGrid}" CommandParameter="{x:Bind}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource PrimaryLightColor}"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource PrimaryMutedColor}"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        </Grid>
    </Grid>
</Page>
