<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.Src.View.General.EnterYourIdPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:vm="using:AirportApp.Src.ViewModel"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirportApp.Src.View.General"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Light"
    >
    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <!-- Navbar placeholder -->
            <RowDefinition Height="Auto"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- ========================= -->
        <!-- NAVBAR (Currently empty)  -->
        <!-- ========================= -->
        <Grid x:Name="TopNavBar"
              Grid.Row="0"
              Height="60"
              Background="Transparent"
              Visibility="Collapsed">
        </Grid>
        <Grid Grid.Row="1">
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="350">
                <!-- Card -->
                <Border Background="{ThemeResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel Spacing="16">
                        <!-- Icon -->
                        <Grid HorizontalAlignment="Center"
                              Width="48"
                              Height="48"
                              CornerRadius="24"
                              Background="{ThemeResource PrimaryBrush}">
                            <FontIcon Glyph="&#xE715;"
                                      Foreground="White"
                                      FontSize="20"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        <!-- Title -->
                        <TextBlock Text="Welcome to Assistance Chat"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center"/>

                                   
                        <!-- Subtitle -->
                        <TextBlock Text="Please enter your User ID to continue"
                                   FontSize="12"
                                   Foreground="{ThemeResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <!-- Input -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="User ID"
                                       FontSize="12"
                                       Foreground="{ThemeResource SecondaryTextBrush}"/>
                            <TextBox PlaceholderText="Enter your ID"
                                     Background="{ThemeResource CardBackgroundBrush}"
                                     Text="{x:Bind ViewModel.UserIdentification, Mode=TwoWay}"
                                     Height="36"/>

                        </StackPanel>
                        <!-- Button -->
                        <Button Content="Continue"
                                Height="46"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Click="LoginButton_Click"
                                Background="{ThemeResource PrimaryBrush}"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                CornerRadius="8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <Button x:Name="BackButton"
        Click="BackButton_Click"
        Margin="24"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Background="Transparent"
        BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Back to Welcome" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
            </StackPanel>
        </Button>
    </Grid>
</Page>