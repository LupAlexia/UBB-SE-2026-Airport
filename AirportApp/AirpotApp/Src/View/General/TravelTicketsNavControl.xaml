<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AirportApp.Src.View.General.TravelTicketsNavControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Light">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TabActiveBackground" Color="#2bb8c0"/>
        <SolidColorBrush x:Key="TabActiveForeground" Color="White"/>
        <SolidColorBrush x:Key="TabInactiveBackground" Color="White"/>
        <SolidColorBrush x:Key="TabInactiveForeground" Color="#2bb8c0"/>

        <Style x:Key="TravelTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2bb8c0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2bb8c0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White"
          Padding="24,16"
          BorderBrush="#E5E7EB"
          BorderThickness="0,0,0,1">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Flights" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="Search flights, review your tickets, or manage memberships."
                       FontSize="13" Foreground="#6B7280"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Button x:Name="SearchTabButton"
                    Content="Search"
                    Style="{StaticResource TravelTabButtonStyle}"
                    Click="OnSearchRequested"/>
            <Button x:Name="MyTicketsTabButton"
                    Content="My Tickets"
                    Style="{StaticResource TravelTabButtonStyle}"
                    Click="OnMyTicketsRequested"/>
            <Button x:Name="MembershipsTabButton"
                    Content="Memberships"
                    Style="{StaticResource TravelTabButtonStyle}"
                    Click="OnMembershipsRequested"/>
        </StackPanel>

        <Button Grid.Column="2"
                Margin="24,0,0,0"
                Height="38"
                Padding="14,0"
                CornerRadius="8"
                Background="Transparent"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                Foreground="#6B7280"
                VerticalAlignment="Center"
                Click="OnHomeRequested">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE80F;" FontSize="14" Foreground="#6B7280"/>
                <TextBlock Text="Home" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
