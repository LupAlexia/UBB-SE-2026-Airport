<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.Src.View.General.UserHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Light">

    <Page.Resources>
        <Style x:Key="HomeCardStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="320"/>
            <Setter Property="Height" Value="240"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource PrimaryBrush}">
                        <FontIcon Glyph="&#xE709;" FontSize="18" Foreground="White"/>
                    </Border>
                    <TextBlock Text="AirportApp"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="SwitchToEmployeeButton"
                        Click="SwitchToEmployeeButton_Click"
                        Background="Transparent"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE716;" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Text="Switch to Employee"
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="48"
                        Padding="40,60">

                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Welcome back"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="What would you like to do today?"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose a service to get started"
                               FontSize="15"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="32"
                            HorizontalAlignment="Center">

                    <Button x:Name="CustomerSupportButton"
                            Style="{StaticResource HomeCardStyle}"
                            Click="CustomerSupportButton_Click">
                        <Grid>
                            <Border VerticalAlignment="Top"
                                    Height="6"
                                    CornerRadius="16,16,0,0"
                                    Background="{StaticResource PrimaryBrush}"/>

                            <StackPanel Spacing="20"
                                        Padding="32,40,32,32"
                                        VerticalAlignment="Center">

                                <Border Width="64"
                                        Height="64"
                                        CornerRadius="16"
                                        Background="{StaticResource PrimaryMutedBrush}"
                                        HorizontalAlignment="Left">
                                    <FontIcon Glyph="&#xE8BD;"
                                              FontSize="28"
                                              Foreground="{StaticResource PrimaryBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Customer Support"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="Chat, FAQ, support tickets and reviews"
                                               FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Background="{StaticResource PrimaryMutedBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Chat Bot" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                    <Border Background="{StaticResource PrimaryMutedBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="FAQ" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                    <Border Background="{StaticResource PrimaryMutedBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Reviews" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="ManageTicketsButton"
                            Style="{StaticResource HomeCardStyle}"
                            Click="ManageTicketsButton_Click">
                        <Grid>
                            <Border VerticalAlignment="Top"
                                    Height="6"
                                    CornerRadius="16,16,0,0"
                                    Background="{StaticResource PrimaryBrush}"/>

                            <StackPanel Spacing="20"
                                        Padding="32,40,32,32"
                                        VerticalAlignment="Center">

                                <Border Width="64"
                                        Height="64"
                                        CornerRadius="16"
                                        Background="{StaticResource PrimaryMutedBrush}"
                                        HorizontalAlignment="Left">
                                    <FontIcon Glyph="&#xE709;"
                                              FontSize="28"
                                              Foreground="{StaticResource PrimaryBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Manage Travel Tickets"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="Search flights, dashboard and memberships"
                                               FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Background="{StaticResource PrimaryMutedBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Flights" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                    <Border Background="{StaticResource PrimaryMutedBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Dashboard" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                    <Border Background="{StaticResource PrimaryMutedBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Members" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="DutyFreeButton"
                            Style="{StaticResource HomeCardStyle}"
                            Click="DutyFreeButton_Click">
                        <Grid>
                            <Border VerticalAlignment="Top"
                                    Height="6"
                                    CornerRadius="16,16,0,0"
                                    Background="{StaticResource WarningBrush}"/>

                            <StackPanel Spacing="20"
                                        Padding="32,40,32,32"
                                        VerticalAlignment="Center">

                                <Border Width="64"
                                        Height="64"
                                        CornerRadius="16"
                                        Background="#FEF3C7"
                                        HorizontalAlignment="Left">
                                    <FontIcon Glyph="&#xE7BF;"
                                              FontSize="28"
                                              Foreground="{StaticResource WarningBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Duty Free"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="Browse shops, select items and add to cart"
                                               FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Background="#FEF3C7" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Shops" FontSize="11" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                    <Border Background="#FEF3C7" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Cart" FontSize="11" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                    <Border Background="#FEF3C7" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Items" FontSize="11" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="40,16">
            <TextBlock Text="AirportApp © 2026 — UBB SE"
                       FontSize="12"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Page>
