<Page
    x:Class="AirportApp.Src.View.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirportApp.Src.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

            <TextBlock Text="{x:Bind ViewModel.TitleText, Mode=OneWay, FallbackValue='Title'}" 
                       FontSize="32" FontWeight="Bold" Foreground="#2bb8c0" HorizontalAlignment="Center"/>

            <TextBlock Text="{x:Bind ViewModel.SubtitleText, Mode=OneWay, FallbackValue='Subtitle'}" 
                       FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>

            <TextBox x:Name="emailInput" PlaceholderText="Email" Width="300" 
                     Text="{x:Bind ViewModel.EmailText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     InputScope="EmailSmtpAddress" />

            <PasswordBox x:Name="passwordInput" PlaceholderText="Password" Width="300" 
                         PasswordChanged="Password_PasswordChanged" />

            <Button Content="{x:Bind ViewModel.ActionButtonLabel, Mode=OneWay, FallbackValue='Submit'}" 
                    Command="{x:Bind ViewModel.ActionCommand}"
                    Background="#2bb8c0" Foreground="White" 
                    Width="300" Height="40" CornerRadius="8" 
                    FontWeight="Bold" Margin="0,10,0,0"
                    HorizontalAlignment="Center" HorizontalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>