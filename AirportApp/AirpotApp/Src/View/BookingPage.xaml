<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AirportApp.Src.View.BookingPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirportApp.Src.View"
    xmlns:vm="using:AirportApp.Src.ViewModel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" Margin="0,0,20,0">
            <StackPanel>
                <TextBlock Text="Complete Your Booking" FontSize="28" FontWeight="Bold" Foreground="#2bb8c0" Margin="0,0,0,20"/>

                <!-- Passengers List -->
                <Border BorderBrush="#2bb8c0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Passengers" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Margin="0,0,0,10" Foreground="Gray">
                            <Run Text="Maximum passengers for this booking: "/>
                            <Run Text="{x:Bind ViewModel.MaximumPassengers, Mode=OneWay}"/>
                        </TextBlock>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Passengers, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PassengerFormViewModel">
                                    <StackPanel Margin="0,0,0,15" Background="#112bb8c0" Padding="10" CornerRadius="8">
                                        <TextBlock Text="Passenger Details" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Grid RowSpacing="10" ColumnSpacing="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox Header="First Name" Text="{x:Bind FirstName, Mode=TwoWay}" Grid.Row="0" Grid.Column="0"/>
                                            <TextBox Header="Last Name" Text="{x:Bind LastName, Mode=TwoWay}" Grid.Row="0" Grid.Column="1"/>
                                            <TextBox Header="Email" Text="{x:Bind Email, Mode=TwoWay}" Grid.Row="1" Grid.Column="0"/>
                                            <TextBox Header="Phone" Text="{x:Bind Phone, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>
                                        </Grid>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Text="Add-Ons:" FontWeight="SemiBold" Margin="0,0,0,5" />
                                            <ListView ItemsSource="{Binding ElementName=RootPage, Path=ViewModel.AvailableAddOns}"
                                                      SelectionMode="Multiple"
                                                      SelectionChanged="AddOnList_SelectionChanged"
                                                      Tag="{Binding}" MaxHeight="100">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock>
                                                            <Run Text="{Binding Name}" /> - <Run Text="{Binding BasePrice}" /> €
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Selected Seat: " VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind SelectedSeat, Mode=OneWay}" FontWeight="Bold" Margin="5,0,10,0" VerticalAlignment="Center"/>
                                            <Button Content="Remove Passenger" 
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RemovePassengerCommand}" 
                                                    IsEnabled="{Binding ElementName=RootPage, Path=ViewModel.CanRemovePassenger}"
                                                    CommandParameter="{Binding}" 
                                                    Background="#d9534f" Foreground="White" CornerRadius="4"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="+ Add Passenger" Command="{x:Bind ViewModel.AddPassengerCommand}" IsEnabled="{x:Bind ViewModel.CanAddPassenger, Mode=OneWay}" Background="Transparent" Foreground="#2bb8c0" BorderBrush="#2bb8c0" BorderThickness="1" Margin="0,10,0,0" CornerRadius="4"/>
                    </StackPanel>
                </Border>

                <!-- Seat Map -->
                <Border BorderBrush="#2bb8c0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Interactive Seat Map" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10" VerticalAlignment="Center">
                            <TextBlock Text="Assign seat to:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="seatPassengerSelector"
                                      Width="180"
                                      ItemsSource="{x:Bind ViewModel.Passengers, Mode=OneWay}"
                                      DisplayMemberPath="PassengerLabel"
                                      SelectionChanged="SeatPassengerSelector_SelectionChanged"/>
                        </StackPanel>
                        <Grid x:Name="seatMapGrid" HorizontalAlignment="Left">
                        </Grid>
                        <TextBlock Text="Legend: light gray = available, teal = selected passenger seat, medium gray = occupied"
                                   Foreground="Gray"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Order Summary side panel -->
        <Border Grid.Column="1" BorderBrush="#2bb8c0" BorderThickness="1" CornerRadius="8" Padding="16" Background="#f8fcfc" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Order Summary" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="#333"/>

                <Grid Margin="0,5">
                    <TextBlock Text="Base Price / person:" HorizontalAlignment="Left"/>
                    <TextBlock Text="{x:Bind ViewModel.BasePricePerPersonDisplay, Mode=OneWay}" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>

                <Grid Margin="0,5">
                    <TextBlock Text="Base Total:" HorizontalAlignment="Left"/>
                    <TextBlock Text="{x:Bind ViewModel.BasePriceTotalDisplay, Mode=OneWay}" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>

                <Grid Margin="0,5">
                    <TextBlock Text="Add-ons:" HorizontalAlignment="Left"/>
                    <TextBlock Text="{x:Bind ViewModel.AddOnsTotalDisplay, Mode=OneWay}" HorizontalAlignment="Right" FontWeight="Bold"/>
                </Grid>

                <Grid Margin="0,5">
                    <TextBlock Text="Membership saves:" HorizontalAlignment="Left"/>
                    <TextBlock Text="{x:Bind ViewModel.MembershipSavingsDisplay, Mode=OneWay}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#2bb8c0"/>
                </Grid>

                <Rectangle Height="1" Fill="#ddd" Margin="0,10"/>

                <Grid Margin="0,5">
                    <TextBlock Text="TOTAL:" FontSize="18" FontWeight="Bold" HorizontalAlignment="Left" Foreground="#333"/>
                    <TextBlock Text="{x:Bind ViewModel.FinalTotalPriceDisplay, Mode=OneWay}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#2bb8c0"/>
                </Grid>

                <Button Content="Confirm Booking" 
                        Command="{x:Bind ViewModel.ConfirmBookingCommand}" 
                        Background="#2bb8c0" Foreground="White" FontWeight="Bold" 
                        Height="45" HorizontalAlignment="Stretch" CornerRadius="8" Margin="0,20,0,0"/>

                <TextBlock Text="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}"
                           TextWrapping="WrapWholeWords"
                           Foreground="#b22222"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>